{%- liquid
  assign glb_url = 'finalback.glb' | asset_url
  assign h1      = section.settings.heading_line1 | default: 'REVIVE'
  assign h2      = section.settings.heading_line2 | default: 'YOUR'
  assign h3      = section.settings.heading_line3 | default: 'GYM.'
  assign sub     = section.settings.subheading | default: 'Professional Floor Restoration for Rubber Floors & Equipment'
  assign btn1_l  = section.settings.btn_primary_label   | default: 'Shop Now'
  assign btn1_u  = section.settings.btn_primary_url     | default: '/products/floorx'
  assign btn2_l  = section.settings.btn_secondary_label | default: 'Watch Demo'
  assign btn2_u  = section.settings.btn_secondary_url   | default: '#'
  assign prob_t  = section.settings.problem_title | default: 'Why Gym Floors Lose Their Finish'
  assign cta_t   = section.settings.cta_title    | default: 'Ready To Transform Your Gym?'
  assign sid     = section.id
-%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
/* ══════════════════════════════════════════════════════
   FX CINEMATIC HERO — Header Overrides (global, scoped)
   Fires when this section is on the page
   ══════════════════════════════════════════════════════ */

/* Nav items: reduce padding so all fit one row */
.header__menu-item {
  padding: 0.7rem 0.85rem !important;
  font-size: 12px !important;
  letter-spacing: 0.07em !important;
}
.list-menu__item--link {
  padding: 0.55rem 0.85rem !important;
  font-size: 12px !important;
}

/* Header stays transparent over cinematic hero */
.header-wrapper {
  background: transparent;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
  border-bottom: none;
  transition: background 0.5s ease, backdrop-filter 0.5s ease;
}

/* Force the main content to ignore the header's height so the hero sits perfectly at the top of the screen */
body.gradient main#MainContent {
  padding-top: 0 !important;
}
main#MainContent {
  padding-top: 0 !important;
}

/* ══════════════════════════════════════════════════════
   FX CINEMATIC HERO — Design Tokens & Reset
   ══════════════════════════════════════════════════════ */
#fx-ch-{{ sid }} {
  --fxch-bg:        #05060A;
  --fxch-panel:     #0F141B;
  --fxch-accent:    #7DF9FF;
  --fxch-text:      #F4F8FF;
  --fxch-muted:     rgba(255,255,255,.62);
  --fxch-glow:      rgba(125,249,255,.35);
  --fxch-display:   'Anton', Impact, sans-serif;
  --fxch-body:      'Space Grotesk', -apple-system, BlinkMacSystemFont, sans-serif;
}

/* â”€â”€â”€ WRAPPER: 300vh scroll container â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
#fx-ch-{{ sid }} {
  position: relative;
  height: 300vh;
  background: var(--fxch-bg);
  isolation: isolate;
  /* Prevent the theme's section reveal from fighting us */
  opacity: 1 !important;
  transform: none !important;
}

/* ─── STICKY VIEWPORT ─────────────────────── */
.fxch-sticky-{{ sid }} {
  position: sticky;
  top: 0;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  background: var(--fxch-bg);
}

/* ─── THREE.JS CANVAS ─────────────────────── */
.fxch-canvas-{{ sid }} {
  position: absolute;
  inset: 0;
  width: 100% !important;
  height: 100% !important;
  display: block;
  z-index: 1;
  pointer-events: none;
}

/* â”€â”€â”€ ATMOSPHERE LAYER â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.fxch-atmo-{{ sid }} {
  position: absolute;
  inset: 0;
  z-index: 2;
  pointer-events: none;
}

/* Particle canvas */
.fxch-particles-{{ sid }} {
  position: absolute;
  inset: 0;
  width: 100% !important;
  height: 100% !important;
  mix-blend-mode: screen;
}

/* Volumetric glow blob */
.fxch-glow-{{ sid }} {
  position: absolute;
  width: 700px;
  height: 700px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(125,249,255,.14) 0%, transparent 65%);
  top: 50%;
  left: 50%;
  transform: translate(-50%,-50%);
  filter: blur(60px);
  will-change: left, top, opacity;
  transition: left .08s linear, top .08s linear;
}

/* Floor reflection */
.fxch-reflect-{{ sid }} {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 38%;
  background: linear-gradient(to top,
    rgba(125,249,255,.08) 0%,
    rgba(125,249,255,.03) 45%,
    transparent 100%
  );
  opacity: 0;
}

/* Vignette */
.fxch-vignette-{{ sid }} {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 100% 100% at 50% 50%,
    transparent 38%,
    rgba(5,6,10,.75) 100%
  );
}

/* â”€â”€â”€ PANELS LAYER â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.fxch-panels-{{ sid }} {
  position: absolute;
  inset: 0;
  z-index: 5;
  pointer-events: none;
  font-family: var(--fxch-body);
  color: var(--fxch-text);
}

/* Base panel */
.fxch-panel {
  position: absolute;
  padding: 0;
  max-width: 600px;
  opacity: 0;
  will-change: opacity;
}

/* Hero: left, vertically centred */
.fxch-panel--hero {
  left: 7vw;
  top: 50%;
  transform: translateY(-50%);
  pointer-events: auto;
}

/* Problem: right side */
.fxch-panel--problem {
  right: 6vw;
  top: 50%;
  transform: translateY(-50%);
  max-width: 420px;
}

/* Features: left side */
.fxch-panel--features {
  left: 7vw;
  top: 50%;
  transform: translateY(-50%);
}

/* Stats: right */
.fxch-panel--stats {
  right: 6vw;
  top: 50%;
  transform: translateY(-50%);
  max-width: 360px;
}

/* CTA: bottom centre */
.fxch-panel--cta {
  left: 50%;
  bottom: 9vh;
  transform: translateX(-50%);
  text-align: center;
  max-width: 620px;
  pointer-events: auto;
}

/* â”€â”€â”€ TYPOGRAPHY â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.fxch-eyebrow {
  font-family: var(--fxch-body);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: .28em;
  text-transform: uppercase;
  color: var(--fxch-accent);
  margin: 0 0 18px;
}

.fxch-headline {
  font-family: var(--fxch-display);
  font-size: clamp(48px, 6vw, 84px);
  line-height: .91;
  letter-spacing: -.01em;
  color: var(--fxch-text);
  margin: 0 0 26px;
  display: flex;
  flex-direction: column;
}

.fxch-headline span {
  display: block;
}

.fxch-headline__outline {
  color: transparent;
  -webkit-text-stroke: 2px var(--fxch-accent);
}

.fxch-subheading {
  font-size: 14.5px;
  font-weight: 400;
  line-height: 1.65;
  color: var(--fxch-muted);
  margin: 0 0 36px;
  max-width: 360px;
}

.fxch-section-title {
  font-family: var(--fxch-display);
  font-size: clamp(22px, 3vw, 36px);
  line-height: 1.06;
  color: var(--fxch-text);
  margin: 0 0 28px;
  font-weight: 400;
}

.fxch-cta-title {
  font-family: var(--fxch-display);
  font-size: clamp(28px, 4vw, 52px);
  line-height: 1.05;
  color: var(--fxch-text);
  margin: 0 0 32px;
  font-weight: 400;
}

/* â”€â”€â”€ BUTTONS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.fxch-cta-row {
  display: flex;
  gap: 14px;
  align-items: center;
  flex-wrap: wrap;
}

.fxch-panel--cta .fxch-cta-row {
  justify-content: center;
  margin-bottom: 22px;
}

.fxch-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 13px 26px;
  border-radius: 3px;
  font-family: var(--fxch-body);
  font-size: 13.5px;
  font-weight: 600;
  letter-spacing: .06em;
  text-decoration: none;
  cursor: pointer;
  transition: transform .25s cubic-bezier(.4,0,.2,1),
              box-shadow .25s cubic-bezier(.4,0,.2,1),
              background .25s ease,
              border-color .25s ease,
              color .25s ease;
  white-space: nowrap;
}

.fxch-btn--primary {
  background: var(--fxch-accent);
  color: #04060A;
  box-shadow: 0 0 28px rgba(125,249,255,.3);
}
.fxch-btn--primary:hover {
  background: #c8fffe;
  box-shadow: 0 0 55px rgba(125,249,255,.65);
  transform: translateY(-2px);
}
.fxch-btn--primary svg { transition: transform .25s ease; }
.fxch-btn--primary:hover svg { transform: translateX(3px); }

.fxch-btn--ghost {
  background: transparent;
  color: var(--fxch-text);
  border: 1px solid rgba(255,255,255,.22);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}
.fxch-btn--ghost:hover {
  border-color: var(--fxch-accent);
  color: var(--fxch-accent);
  transform: translateY(-2px);
}

.fxch-btn--lg {
  padding: 17px 38px;
  font-size: 15px;
}

@media screen and (max-width: 749px) {
  .fxch-btn {
    padding: 10px 20px;
    font-size: 12px;
  }
  .fxch-btn--lg {
    padding: 13px 26px;
    font-size: 13px;
  }
  .fxch-cta-row {
    gap: 10px;
  }
}

/* â”€â”€â”€ PROBLEM LIST â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.fxch-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.fxch-list li {
  display: flex;
  gap: 15px;
  font-size: 14.5px;
  color: var(--fxch-muted);
  line-height: 1.55;
}
.fxch-list__dash {
  color: var(--fxch-accent);
  font-weight: 700;
  flex-shrink: 0;
}

/* â”€â”€â”€ FEATURES â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.fxch-features {
  display: flex;
  flex-direction: column;
  gap: 13px;
}
.fxch-feature {
  display: flex;
  align-items: center;
  gap: 14px;
  font-size: 14.5px;
  color: var(--fxch-muted);
}
.fxch-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--fxch-accent);
  box-shadow: 0 0 8px var(--fxch-accent);
  flex-shrink: 0;
}

/* â”€â”€â”€ STATS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.fxch-stats {
  display: flex;
  flex-direction: column;
  gap: 28px;
}
.fxch-stat__val {
  font-family: var(--fxch-display);
  font-size: 68px;
  line-height: 1;
  color: var(--fxch-text);
  display: block;
}
.fxch-stat__sup {
  color: var(--fxch-accent);
  font-size: 40px;
}
.fxch-stat__lbl {
  font-size: 12px;
  color: var(--fxch-muted);
  letter-spacing: .12em;
  text-transform: uppercase;
  display: block;
  margin-top: 4px;
}

/* â”€â”€â”€ TRUST BADGES â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.fxch-trust {
  display: flex;
  gap: 22px;
  justify-content: center;
  font-size: 12.5px;
  color: var(--fxch-muted);
  flex-wrap: wrap;
  letter-spacing: .03em;
}

/* â”€â”€â”€ SCROLL INDICATOR â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.fxch-scroll-ind {
  position: absolute;
  bottom: 36px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  z-index: 6;
  opacity: 0;
  will-change: opacity;
}
.fxch-scroll-ind__txt {
  font-family: var(--fxch-body);
  font-size: 9px;
  letter-spacing: .24em;
  text-transform: uppercase;
  color: var(--fxch-muted);
}
.fxch-scroll-ind__line {
  width: 1px;
  height: 46px;
  background: rgba(255,255,255,.1);
  position: relative;
  overflow: hidden;
}
.fxch-scroll-ind__dot {
  position: absolute;
  top: -8px;
  left: -3px;
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--fxch-accent);
  box-shadow: 0 0 8px var(--fxch-accent);
  animation: fxch-scroll-drop 2s ease-in-out infinite;
}
@keyframes fxch-scroll-drop {
  0%   { top: -8px; opacity: 0; }
  18%  { opacity: 1; }
  82%  { opacity: .7; }
  100% { top: 100%; opacity: 0; }
}

/* â”€â”€â”€ LOADING OVERLAY â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.fxch-loading-{{ sid }} {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: #05060A;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity .9s ease, visibility .9s ease;
}
.fxch-loading-{{ sid }}.is-hidden {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}
.fxch-loading__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 22px;
}
.fxch-loading__brand {
  font-family: var(--fxch-display);
  font-size: 46px;
  color: var(--fxch-accent);
  letter-spacing: .22em;
  animation: fxch-breathe 2.2s ease-in-out infinite;
}
@keyframes fxch-breathe {
  0%,100% { opacity: 1; }
  50%      { opacity: .45; }
}
.fxch-loading__bar-wrap {
  width: 210px;
  height: 2px;
  background: rgba(255,255,255,.1);
  border-radius: 2px;
  overflow: hidden;
}
.fxch-loading__bar {
  height: 100%;
  background: var(--fxch-accent);
  box-shadow: 0 0 10px var(--fxch-accent);
  border-radius: 2px;
  width: 0%;
  transition: width .3s ease;
}
.fxch-loading__lbl {
  font-family: var(--fxch-body);
  font-size: 10px;
  letter-spacing: .22em;
  color: var(--fxch-muted);
  text-transform: uppercase;
}

/* â”€â”€â”€ RESPONSIVE â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
@media (max-width: 768px) {
  .fxch-panel--hero {
    left: 5vw;
    right: 5vw;
    top: auto;
    bottom: 16vh;
    transform: none;
    max-width: 100%;
  }
  .fxch-panel--problem,
  .fxch-panel--features,
  .fxch-panel--stats {
    left: 5vw;
    right: 5vw;
    top: auto;
    bottom: 13vh;
    transform: none;
    max-width: 100%;
  }
  .fxch-panel--cta {
    left: 5vw;
    right: 5vw;
    transform: none;
    bottom: 9vh;
    text-align: left;
    max-width: 100%;
  }
  .fxch-panel--cta .fxch-cta-row { justify-content: flex-start; }
  .fxch-trust { justify-content: flex-start; }
  .fxch-headline { font-size: clamp(52px, 14vw, 80px); }
  .fxch-stats { flex-direction: row; gap: 20px; flex-wrap: wrap; }
  .fxch-stat__val { font-size: 48px; }
  .fxch-glow-{{ sid }} { width: 320px; height: 320px; }
}

/* â”€â”€â”€ REDUCED MOTION â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
@media (prefers-reduced-motion: reduce) {
  .fxch-scroll-ind__dot,
  .fxch-loading__brand { animation: none; opacity: 1; }
  .fxch-btn { transition: none; }
}
</style>

<!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â• HTML STRUCTURE â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
<div id="fx-ch-{{ sid }}">

  <!-- Loading overlay -->
  <div class="fxch-loading-{{ sid }}" id="fxch-load-{{ sid }}">
    <div class="fxch-loading__inner">
      <div class="fxch-loading__brand">FLOORX</div>
      <div class="fxch-loading__bar-wrap">
        <div class="fxch-loading__bar" id="fxch-bar-{{ sid }}"></div>
      </div>
      <div class="fxch-loading__lbl" id="fxch-lbl-{{ sid }}">Preparing Experience</div>
    </div>
  </div>

  <!-- Sticky 100vh viewport -->
  <div class="fxch-sticky-{{ sid }}" id="fxch-sticky-{{ sid }}">

    <!-- Three.js Canvas -->
    <canvas class="fxch-canvas-{{ sid }}" id="fxch-canvas-{{ sid }}"></canvas>

    <!-- Atmospheric overlays -->
    <div class="fxch-atmo-{{ sid }}">
      <canvas class="fxch-particles-{{ sid }}" id="fxch-pts-{{ sid }}"></canvas>
      <div class="fxch-glow-{{ sid }}" id="fxch-glow-{{ sid }}"></div>
      <div class="fxch-reflect-{{ sid }}" id="fxch-ref-{{ sid }}"></div>
      <div class="fxch-vignette-{{ sid }}"></div>
    </div>

    <!-- Content panels -->
    <div class="fxch-panels-{{ sid }}">

      <!-- PANEL 0: Hero text (left) -->
