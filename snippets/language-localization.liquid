{%- comment -%}
  Renders the language picker for the localization form
  Accepts:
    - localPosition: pass in the position in which the form is coming up to create specific IDs
{%- endcomment -%}

{%- liquid
  assign target_language = null
  for language in localization.available_languages
    if language.iso_code != localization.language.iso_code
      assign target_language = language
      break
    endif
  endfor
-%}

{%- if target_language -%}
  <a
    href="#"
    hreflang="{{ target_language.iso_code }}"
    lang="{{ target_language.iso_code }}"
    data-value="{{ target_language.iso_code }}"
    class="header__icon header__icon--language link link--text"
    style="text-transform: uppercase; text-decoration: none; font-weight: 700; font-size: 1rem; padding: 0.5rem; margin: 0; color: inherit; display: flex; align-items: center; justify-content: center; width: 44px; height: 44px; border-radius: 10px;"
  >
    {{ target_language.iso_code }}
  </a>
  <input type="hidden" name="locale_code" value="{{ localization.language.iso_code }}">
  
  {%- comment -%} Dummy elements to prevent Dawn's JS from crashing {%- endcomment -%}
  <button type="button" class="hidden" style="display: none !important;"></button>
  <div class="disclosure__list-wrapper hidden" hidden style="display: none !important;"></div>
{%- else -%}
  <input type="hidden" name="locale_code" value="{{ localization.language.iso_code }}">
  <button type="button" class="hidden" style="display: none !important;"></button>
  <div class="disclosure__list-wrapper hidden" hidden style="display: none !important;"></div>
{%- endif -%}