{{ 'fx-faq-stage.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign sid = section.id
  assign faq_eyebrow = section.settings.eyebrow
  if faq_eyebrow == blank or faq_eyebrow == 'Support'
    assign faq_eyebrow = 'floorx.faq.eyebrow' | t
  endif
  assign faq_heading = section.settings.heading
  if faq_heading == blank or faq_heading == 'Frequently Asked Questions'
    assign faq_heading = 'floorx.faq.heading' | t
  endif
  assign faq_subtitle = section.settings.subtitle
  if faq_subtitle == blank or faq_subtitle == 'Find answers to our most frequently asked questions.'
    assign faq_subtitle = 'floorx.faq.subtitle' | t
  endif
  assign faq_answer = section.settings.answer_label
  if faq_answer == blank or faq_answer == 'Answer'
    assign faq_answer = 'floorx.faq.answer' | t
  endif
  assign faq_help_t = section.settings.help_title
  if faq_help_t == blank or faq_help_t == 'Still have questions?'
    assign faq_help_t = 'floorx.faq.help_title' | t
  endif
  assign faq_help_x = section.settings.help_text
  if faq_help_x == blank or faq_help_x == "We're here to help!"
    assign faq_help_x = 'floorx.faq.help_text' | t
  endif
  assign faq_help_b = section.settings.help_btn
  if faq_help_b == blank or faq_help_b == 'Contact support'
    assign faq_help_b = 'floorx.faq.help_btn' | t
  endif
  assign faq_b1 = section.settings.badge_1
  if faq_b1 == blank or faq_b1 == 'Belt Safe'
    assign faq_b1 = 'floorx.faq.badge_1' | t
  endif
  assign faq_b2 = section.settings.badge_2
  if faq_b2 == blank or faq_b2 == 'Non-Abrasive'
    assign faq_b2 = 'floorx.faq.badge_2' | t
  endif
  assign faq_b3 = section.settings.badge_3
  if faq_b3 == blank or faq_b3 == 'Trusted by Gyms'
    assign faq_b3 = 'floorx.faq.badge_3' | t
  endif
-%}

<section
  id="fx-faq"
  class="fx-faq-stage fx-page-stage fx-faq-stage--no-3d"
  data-fx-faq-stage
  data-fx-chapter="faq"
  aria-label="{{ faq_heading | escape }}"
>
  <div class="fx-faq-stage__inner">
    <header class="fx-faq-stage__header">
      <p class="fx-faq-stage__eyebrow">{{ faq_eyebrow | escape }}</p>
      <h2 class="fx-faq-stage__title">{{ faq_heading | escape }}</h2>
      <p class="fx-faq-stage__subtitle">{{ faq_subtitle | escape }}</p>
    </header>

    <div class="fx-faq-stage__grid">
      {%- comment -%} Questions accordion list {%- endcomment -%}
      <div class="fx-faq-stage__panel fx-faq-stage__qlist-panel">
        <div class="fx-faq-stage__qlist" role="list">
          {%- assign q_index = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'question' -%}
              {%- liquid
                assign q_index = q_index | plus: 1
                assign icon_i = q_index | modulo: 5
                assign q_text = block.settings.question
                assign a_text = block.settings.answer
                case q_text
                  when 'Is FloorX safe for treadmills?'
                    assign q_text = 'floorx.faq.q1' | t
                    assign a_text = 'floorx.faq.a1' | t
                  when 'Can FloorX be used on rubber gym floors?'
                    assign q_text = 'floorx.faq.q2' | t
                    assign a_text = 'floorx.faq.a2' | t
                  when 'How often should FloorX be used?'
                    assign q_text = 'floorx.faq.q3' | t
                    assign a_text = 'floorx.faq.a3' | t
                  when 'Does the product damage treadmill belts?'
                    assign q_text = 'floorx.faq.q4' | t
                    assign a_text = 'floorx.faq.a4' | t
                  when 'Can the product remove shoe marks and fingerprints?'
                    assign q_text = 'floorx.faq.q5' | t
                    assign a_text = 'floorx.faq.a5' | t
                  when 'Do I need special equipment to use FloorX?'
                    assign q_text = 'floorx.faq.q6' | t
                    assign a_text = 'floorx.faq.a6' | t
                  when 'Where can I use FloorX?'
                    assign q_text = 'floorx.faq.q7' | t
                    assign a_text = 'floorx.faq.a7' | t
                endcase
              -%}
              <div
                class="fx-faq-stage__qitem{% if q_index == 1 %} is-open is-active{% endif %}"
                role="listitem"
                {{ block.shopify_attributes }}
              >
                <button
                  type="button"
                  class="fx-faq-stage__qbtn{% if q_index == 1 %} is-active{% endif %}"
                  data-fx-faq-q
                  data-title="{{ q_text | escape }}"
                  data-answer="{{ a_text | escape }}"
                  aria-expanded="{% if q_index == 1 %}true{% else %}false{% endif %}"
                  aria-controls="fx-faq-panel-{{ sid }}-{{ block.id }}"
                  id="fx-faq-btn-{{ sid }}-{{ block.id }}"
                >
                  <span class="fx-faq-stage__qicon" aria-hidden="true">
                    {%- case icon_i -%}
                      {%- when 1 -%}
                        <svg viewBox="0 0 24 24" fill="none"><path d="M12 3l7 3v6c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z" stroke="currentColor" stroke-width="1.6"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                      {%- when 2 -%}
                        <svg viewBox="0 0 24 24" fill="none"><path d="M4 8h16v10H4zM8 8V6h8v2M7 18v2M17 18v2" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
                      {%- when 3 -%}
                        <svg viewBox="0 0 24 24" fill="none"><rect x="4" y="5" width="16" height="15" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M8 3v4M16 3v4M4 10h16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                      {%- when 4 -%}
                        <svg viewBox="0 0 24 24" fill="none"><path d="M4 8h12v8H4zM16 10h3l2 2v4h-5V10z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
                      {%- else -%}
                        <svg viewBox="0 0 24 24" fill="none"><path d="M12 11a3 3 0 00-3 3v2M12 7a7 7 0 017 7v1M5 14v-1a7 7 0 014.5-6.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                    {%- endcase -%}
                  </span>
                  <span class="fx-faq-stage__qlabel">{{ q_text | escape }}</span>
                  <span class="fx-faq-stage__qtoggle" aria-hidden="true">
                    <span class="fx-faq-stage__qtoggle-plus">+</span>
                    <span class="fx-faq-stage__qtoggle-minus">−</span>
                  </span>
                </button>

                <div
                  class="fx-faq-stage__expand"
                  id="fx-faq-panel-{{ sid }}-{{ block.id }}"
                  role="region"
                  aria-labelledby="fx-faq-btn-{{ sid }}-{{ block.id }}"
                  aria-hidden="{% if q_index == 1 %}false{% else %}true{% endif %}"
                >
                  <div class="fx-faq-stage__expand-inner">
                    <p class="fx-faq-stage__expand-kicker">{{ faq_answer | escape }}</p>
                    <div class="fx-faq-stage__expand-body">{{ a_text | escape | newline_to_br }}</div>
                    <div class="fx-faq-stage__expand-badges">
                      <span class="fx-faq-stage__chip">
                        <span class="fx-faq-stage__chip-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3l7 3v6c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z" stroke="currentColor" stroke-width="1.5"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></span>
                        {{ faq_b1 | escape }}
                      </span>
                      <span class="fx-faq-stage__chip">
                        <span class="fx-faq-stage__chip-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M12 8v4l2.5 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></span>
                        {{ faq_b2 | escape }}
                      </span>
                      <span class="fx-faq-stage__chip">
                        <span class="fx-faq-stage__chip-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M12 17l-5 2 1-5.5L4 9.5l5.5-.8L12 4l2.5 4.7 5.5.8-4 3.9 1 5.6-5-2z" stroke="currentColor" stroke-width="1.5"/></svg></span>
                        {{ faq_b3 | escape }}
                      </span>
                    </div>
                  </div>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        <div class="fx-faq-stage__help">
          <div class="fx-faq-stage__help-copy">
            <span class="fx-faq-stage__help-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none"><path d="M4 6a2 2 0 012-2h4l2 3H8v4h3l-2 5H6a2 2 0 01-2-2V6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M14 8h4a2 2 0 012 2v6a2 2 0 01-2 2h-2l-3 2v-2h-1a2 2 0 01-2-2v-1" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
            </span>
            <div>
              <strong>{{ faq_help_t | escape }}</strong>
              <em>{{ faq_help_x | escape }}</em>
            </div>
          </div>
          {%- liquid
            assign help_href = section.settings.help_link
            if help_href == blank
              if pages.contact != blank
                assign help_href = pages.contact.url
              else
                assign help_href = '/pages/contact' | prepend: routes.root_url | replace: '//', '/'
              endif
            endif
          -%}
          <a class="fx-faq-stage__help-btn" href="{{ help_href }}">
            {{ faq_help_b | escape }}
          </a>
        </div>
      </div>

      <div class="fx-faq-stage__panel fx-faq-stage__answer" data-fx-faq-answer aria-live="polite">
        <p class="fx-faq-stage__answer-kicker">{{ faq_answer | escape }}</p>
        <h3 class="fx-faq-stage__answer-title" data-fx-faq-title>
          {%- if section.blocks.first -%}
            {%- liquid
              assign first_q = section.blocks.first.settings.question
              case first_q
                when 'Is FloorX safe for treadmills?'
                  echo 'floorx.faq.q1' | t
                else
                  echo first_q
              endcase
            -%}
          {%- endif -%}
        </h3>
        <div class="fx-faq-stage__answer-body" data-fx-faq-body>
          {%- if section.blocks.first -%}
            {%- liquid
              assign first_a = section.blocks.first.settings.answer
              case section.blocks.first.settings.question
                when 'Is FloorX safe for treadmills?'
                  echo 'floorx.faq.a1' | t
                else
                  echo first_a
              endcase
            -%}
          {%- endif -%}
        </div>

        <div class="fx-faq-stage__badges">
          <div class="fx-faq-stage__badge">
            <span class="fx-faq-stage__badge-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none"><path d="M12 3l7 3v6c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z" stroke="currentColor" stroke-width="1.5"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </span>
            <span>{{ faq_b1 | escape }}</span>
          </div>
          <div class="fx-faq-stage__badge">
            <span class="fx-faq-stage__badge-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M12 8v4l2.5 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </span>
            <span>{{ faq_b2 | escape }}</span>
          </div>
          <div class="fx-faq-stage__badge">
            <span class="fx-faq-stage__badge-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none"><path d="M12 17l-5 2 1-5.5L4 9.5l5.5-.8L12 4l2.5 4.7 5.5.8-4 3.9 1 5.6-5-2z" stroke="currentColor" stroke-width="1.5"/></svg>
            </span>
            <span>{{ faq_b3 | escape }}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script src="{{ 'fx-faq-stage.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "FX FAQ Stage",
  "tag": "section",
  "class": "section-fx-faq-stage",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Support"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Everything you need to know about FloorX"
    },
    {
      "type": "text",
      "id": "answer_label",
      "label": "Answer label",
      "default": "Answer"
    },
    {
      "type": "text",
      "id": "badge_1",
      "label": "Badge 1",
      "default": "Belt Safe"
    },
    {
      "type": "text",
      "id": "badge_2",
      "label": "Badge 2",
      "default": "Non-Abrasive"
    },
    {
      "type": "text",
      "id": "badge_3",
      "label": "Badge 3",
      "default": "Trusted by Gyms"
    },
    {
      "type": "header",
      "content": "Help CTA (mobile)"
    },
    {
      "type": "text",
      "id": "help_title",
      "label": "Help title",
      "default": "Still have questions?"
    },
    {
      "type": "text",
      "id": "help_text",
      "label": "Help text",
      "default": "We're here to help!"
    },
    {
      "type": "text",
      "id": "help_btn",
      "label": "Help button",
      "default": "Contact support"
    },
    {
      "type": "url",
      "id": "help_link",
      "label": "Help link"
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Is FloorX safe for treadmills?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Yes. FloorX is safe to use on treadmill belts and gym machines when used as directed."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FX FAQ Stage",
      "blocks": [
        {
          "type": "question",
          "settings": {
            "question": "Is FloorX safe for treadmills?",
            "answer": "Yes. FloorX is safe to use on treadmill belts and gym machines when used as directed."
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Can FloorX be used on rubber gym floors?",
            "answer": "Yes. The product is designed to work on rubber gym flooring and help keep it clean and looking better."
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "How often should FloorX be used?",
            "answer": "In most gyms, using FloorX once every 30 days is enough to maintain a clean appearance."
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Does the product damage treadmill belts?",
            "answer": "No. FloorX has been tested on treadmills for more than 2 years to ensure it is safe when used correctly."
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Can the product remove shoe marks and fingerprints?",
            "answer": "FloorX helps reduce the appearance of shoe marks and fingerprints that commonly appear on treadmill belts and rubber floors."
          }
        }
      ]
    }
  ]
}
{% endschema %}
