/* SCROLL INDICATOR — sits in the soft navy fade, cyan language */
.fxch-scroll-ind {
  position: absolute;
  bottom: 28px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  z-index: 8;
  opacity: 0;
  will-change: opacity;
  pointer-events: none;
}
.fxch-scroll-ind__txt {
  font-family: var(--fxch-body);
  font-size: 10px;
  letter-spacing: .28em;
  text-transform: uppercase;
  color: rgba(125, 249, 255, 0.55);
  text-shadow: 0 0 12px rgba(125, 249, 255, 0.2);
}
.fxch-scroll-ind__line {
  width: 1px;
  height: 52px;
  background: linear-gradient(
    180deg,
    rgba(125, 249, 255, 0.45) 0%,
    rgba(125, 249, 255, 0.12) 55%,
    transparent 100%
  );
  position: relative;
  overflow: hidden;
}
.fxch-scroll-ind__dot {
  position: absolute;
  top: -8px;
  left: -3px;
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--fxch-accent);
  box-shadow: 0 0 10px rgba(125, 249, 255, 0.65);
  animation: fxch-scroll-drop 2.2s ease-in-out infinite;
}
@keyframes fxch-scroll-drop {
  0%   { top: -8px; opacity: 0; }
  18%  { opacity: 1; }
  82%  { opacity: .55; }
  100% { top: 100%; opacity: 0; }
}

/* Hero secondary loader removed — site logo preloader only */
