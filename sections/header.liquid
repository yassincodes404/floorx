<script>
  // FloorX custom search keyboard shortcuts (Ctrl+K or /)
  document.addEventListener('keydown', (event) => {
    // Ignore if user is already typing in an input
    if (event.target.tagName === 'INPUT' || event.target.tagName === 'TEXTAREA') return;
    
    if (event.key === '/' || (event.key === 'k' && (event.ctrlKey || event.metaKey))) {
      event.preventDefault();
      const searchToggle = document.querySelector('.header__search details summary');
      if (searchToggle) {
        if (!searchToggle.parentElement.hasAttribute('open')) {
          searchToggle.click();
        }
        // Focus the input slightly after the modal opens
        setTimeout(() => {
          const searchInput = document.querySelector('.header__search input[type="search"]');
          if (searchInput) searchInput.focus();
        }, 100);
      }
    }
  });

  // Mobile drawer close button — triggers the same toggle as the burger/X
  document.addEventListener('click', function (event) {
    var closeBtn = event.target.closest('.fx-drawer-close');
    if (!closeBtn) return;
    event.preventDefault();
    event.stopPropagation();
    var details = closeBtn.closest('details.menu-drawer-container');
    if (!details) return;
    var summary = details.querySelector('summary.fx-menu-toggle, summary.header__icon--menu');
    if (summary) summary.click();
  });

  /*
    Hard-hide the site logo (the dark gray plate over HOME) whenever the menu is open.
    Does not rely on Dawn's menu-open class alone.
  */
  (function fxNavSceneChromeGuard() {
    var details = document.getElementById('Details-menu-drawer-container');
    if (!details) return;

    var LOGO_SEL = [
      '.header__heading',
      '.header__heading-link',
      '.header__heading-logo-wrapper',
      '.header__heading-logo',
      'img.header__heading-logo',
      'img.logo',
      'img.logo-light',
      '.logo',
      '.logo-light',
      '.header__icons',
      '.header__inline-menu',
      '.fx-header-cta',
      'summary.fx-menu-toggle',
      'summary.header__icon--menu',
      'a.header__heading-link'
    ].join(',');

    function hideEl(el) {
      if (!el || el.closest('#menu-drawer')) return;
      /* Only hide chrome — do not zero-size layout hosts */
      el.style.setProperty('display', 'none', 'important');
      el.style.setProperty('pointer-events', 'none', 'important');
      el.setAttribute('aria-hidden', 'true');
      if (el.tagName === 'A' || el.tagName === 'SUMMARY') el.setAttribute('tabindex', '-1');
    }

    function showEl(el) {
      if (!el || el.closest('#menu-drawer')) return;
      el.style.removeProperty('display');
      el.style.removeProperty('pointer-events');
      el.removeAttribute('aria-hidden');
      if (el.tagName === 'A' || el.tagName === 'SUMMARY') el.removeAttribute('tabindex');
    }

    function setOpen(isOpen) {
      document.body.classList.toggle('fx-nav-scene-open', !!isOpen);
      document.documentElement.classList.toggle('fx-nav-scene-open', !!isOpen);

      var header = document.getElementById('site-header');
      if (!header) return;

      header.querySelectorAll(LOGO_SEL).forEach(function (el) {
        if (isOpen) hideEl(el);
        else showEl(el);
      });
    }

    function sync() {
      setOpen(details.hasAttribute('open'));
    }

    var mo = new MutationObserver(sync);
    mo.observe(details, { attributes: true, attributeFilter: ['open', 'class'] });
    details.addEventListener('toggle', sync);

    /* Re-apply hide if scroll logo script rewrites inline opacity */
    window.addEventListener('scroll', function () {
      if (document.body.classList.contains('fx-nav-scene-open')) setOpen(true);
    }, { passive: true });

    sync();
  })();
</script>
