}
body.gradient main#MainContent,
main#MainContent {
  padding-top: 0 !important;
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   FX CINEMATIC HERO â€” Design Tokens & Reset
   â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
#fx-ch-{{ sid }} {
  --fxch-bg:        var(--fx-bg-0, #05060A);
  --fxch-panel:     var(--fx-bg-elevated, #0F141B);
  --fxch-accent:    var(--fx-cyan, #7DF9FF);
  --fxch-text:      var(--fx-text-primary, #F4F8FF);
  --fxch-muted:     var(--fx-text-secondary, rgba(255,255,255,.62));
  --fxch-glow:      var(--fx-glow-md, rgba(125,249,255,.35));
  --fxch-display:   var(--fx-font-display, 'Anton', Impact, sans-serif);
  --fxch-body:      var(--fx-font-ui, 'Space Grotesk', system-ui, sans-serif);
}

/* WRAPPER: 300vh scroll — transparent so fixed page video is the stage */
#fx-ch-{{ sid }} {
  position: relative;
  height: 300vh;
  background: transparent !important;
  isolation: auto;
  opacity: 1 !important;
  transform: none !important;
}

/* Sticky viewport open to page video (no solid navy slab) */
.fxch-sticky-{{ sid }} {
  position: sticky;
  top: 0;
  width: 100%;
  height: 100vh;
  height: 100dvh;
  overflow: hidden;
  background: transparent !important;
  background-image: none !important;
}
.fxch-product-slot { display: none; }

/* Video background styling */
.fxch-video-bg {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  z-index: 0;
  opacity: 0.55; /* dimmed so bottle pops */
}

/* ── PORTAL LIGHT SPILL — CSS bloom only ── */
.fxch-portal-{{ sid }} {
  position: absolute;
  z-index: 1;
  pointer-events: none;
  left: 58%;
  top: 50%;
  width: min(90vw, 900px);
  height: min(90vw, 900px);
  transform: translate(-50%, -50%) scale(0.72);
  opacity: 0;
  will-change: transform, opacity;
  mix-blend-mode: screen;
}
.fxch-portal__bloom {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background:
    radial-gradient(circle at 50% 48%,
      rgba(180, 245, 255, 0.55) 0%,
      rgba(80, 170, 255, 0.32) 18%,
      rgba(30, 100, 220, 0.16) 38%,
      rgba(10, 40, 120, 0.06) 58%,
      transparent 72%);
  filter: blur(8px);
  animation: fxch-portal-breathe 4.8s ease-in-out infinite;
}
.fxch-portal__bloom--core {
  inset: 22%;
  background:
    radial-gradient(circle at 50% 50%,
      rgba(220, 250, 255, 0.7) 0%,
      rgba(100, 200, 255, 0.35) 35%,
      transparent 70%);
  filter: blur(12px);
  animation: fxch-portal-breathe 3.2s ease-in-out infinite reverse;
}
.fxch-portal__bloom--ring {
  inset: 8%;
  border-radius: 50%;
  background: transparent;
  box-shadow:
    0 0 60px 20px rgba(60, 150, 255, 0.18),
    0 0 120px 40px rgba(125, 249, 255, 0.1),
    inset 0 0 80px rgba(40, 120, 255, 0.12);
  animation: fxch-portal-breathe 5.5s ease-in-out infinite;
}
@keyframes fxch-portal-breathe {
  0%, 100% { opacity: 0.72; transform: scale(1); }
  50%      { opacity: 1; transform: scale(1.06); }
}

/* ── THREE.JS CANVAS (transparent over portal) ── */
.fxch-canvas-{{ sid }} {
  position: absolute;
  inset: 0;
  width: 100% !important;
  height: 100% !important;
  display: block;
  z-index: 3;
  pointer-events: none;
  background: transparent !important;
}

/* Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ ATMOSPHERE LAYER Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ */
.fxch-atmo-{{ sid }} {
  position: absolute;
  inset: 0;
  z-index: 2;
  pointer-events: none;
}
/* Keep glow/fog under bottle but portal is z1, canvas z3 */



/* Layered glows — hierarchy: huge / medium / core (not one uniform blob) */
.fxch-glow-{{ sid }} {
  position: absolute;
  width: min(130vw, 1200px);
  height: min(130vw, 1200px);
  border-radius: 50%;
  background: radial-gradient(circle,
    rgba(125,249,255,.08) 0%,
    rgba(29,90,180,.12) 28%,
    rgba(10,30,80,.08) 48%,
    transparent 68%);
  top: 48%;
  left: 58%;
  transform: translate(-50%,-50%);
  filter: blur(70px);
  will-change: left, top, opacity, transform;
  animation: fxch-glow-breathe 9s ease-in-out infinite;
  mix-blend-mode: screen;
}
.fxch-glow-mid-{{ sid }} {
  position: absolute;
  width: min(55vw, 520px);
  height: min(55vw, 520px);
  border-radius: 50%;
  left: 58%;
  top: 48%;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle,
    rgba(180, 250, 255, 0.28) 0%,
    rgba(125, 249, 255, 0.14) 35%,
    transparent 70%);
  filter: blur(28px);
  opacity: 0;
  mix-blend-mode: screen;
  will-change: left, top, opacity;
  animation: fxch-glow-mid-breathe 6.5s ease-in-out infinite;
  pointer-events: none;
}
.fxch-glow-core-{{ sid }} {
  display: none !important;
}
@keyframes fxch-glow-breathe {
  0%, 100% { transform: translate(-50%,-50%) scale(0.94); filter: blur(72px) brightness(0.9); }
  50%      { transform: translate(-50%,-50%) scale(1.06); filter: blur(60px) brightness(1.15); }
}
@keyframes fxch-glow-mid-breathe {
  0%, 100% { transform: translate(-50%,-50%) scale(0.96); }
  50%      { transform: translate(-50%,-50%) scale(1.08); }
}
.fxch-fog-layer-{{ sid }} {
  position: absolute;
  inset: -8%;
  background:
    radial-gradient(ellipse 70% 40% at 60% 42%, rgba(125,249,255,.05) 0%, transparent 50%),
    radial-gradient(ellipse 50% 45% at 30% 75%, rgba(15,40,100,.18) 0%, transparent 55%);
  animation: fxch-fog-drift 22s ease-in-out infinite alternate;
  pointer-events: none;
  opacity: 0.85;
}
@keyframes fxch-fog-drift {
  from { transform: translate(0,0) scale(1); }
  to   { transform: translate(-1.5%, 2%) scale(1.03); }
}

/* Soft contact shadow under bottle (CSS companion to 3D) */
.fxch-contact-shadow-{{ sid }} {
  position: absolute;
  width: min(28vw, 280px);
  height: min(8vw, 70px);
  left: 58%;
  top: 72%;
  transform: translate(-50%, -50%);
  background: radial-gradient(ellipse,
    rgba(0, 0, 0, 0.65) 0%,
    rgba(0, 20, 40, 0.25) 45%,
    transparent 72%);
  filter: blur(10px);
  opacity: 0;
  pointer-events: none;
  z-index: 2;
  will-change: left, top, opacity;
}

/* Signature energy pulse ring — fires every ~8s via class */
.fxch-energy-pulse-{{ sid }} {
  position: absolute;
  left: 58%;
  top: 48%;
  width: min(40vw, 380px);
  height: min(40vw, 380px);
  border-radius: 50%;
  border: 1.5px solid rgba(125, 249, 255, 0.0);
  box-shadow: 0 0 0 0 rgba(125, 249, 255, 0);
  transform: translate(-50%, -50%) scale(0.4);
  opacity: 0;
  pointer-events: none;
  z-index: 4;
  mix-blend-mode: screen;
}
.fxch-energy-pulse-{{ sid }}.is-firing {
  animation: fxch-energy-ring 1.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}
@keyframes fxch-energy-ring {
  0%   { opacity: 0; transform: translate(-50%,-50%) scale(0.35); border-color: rgba(125,249,255,0); box-shadow: 0 0 0 0 rgba(125,249,255,0); }
  12%  { opacity: 1; border-color: rgba(180,250,255,0.85); box-shadow: 0 0 40px 8px rgba(125,249,255,0.35); }
  100% { opacity: 0; transform: translate(-50%,-50%) scale(2.1); border-color: rgba(125,249,255,0); box-shadow: 0 0 80px 0 rgba(125,249,255,0); }
}

/* Floor reflection — cool navy, not pure black */
.fxch-reflect-{{ sid }} {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 36%;
  background: linear-gradient(to top,
    rgba(4, 10, 24, 0.55) 0%,
    rgba(125, 249, 255, 0.05) 40%,
    transparent 100%
  );
  opacity: 0;
}

/* Vignette — softer edges, keep blue in the mid field */
.fxch-vignette-{{ sid }} {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 100% 85% at 50% 42%,
      transparent 32%,
      rgba(4, 10, 24, 0.35) 70%,
      rgba(3, 8, 18, 0.72) 100%
    ),
    linear-gradient(180deg,
      rgba(4, 10, 22, 0.2) 0%,
      transparent 18%,
      transparent 58%,
      rgba(4, 10, 22, 0.45) 100%
    );
}

/* CTA glow flash during energy pulse */
.fxch-btn.is-pulse-glow {
  box-shadow:
    0 0 48px rgba(125,249,255,.65),
    0 0 90px rgba(29,106,255,.35),
    0 8px 24px rgba(0,0,0,.3) !important;
}

/* Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ PANELS LAYER Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ */
.fxch-panels-{{ sid }} {
  position: absolute;
  inset: 0;
  z-index: 6;
  pointer-events: none;
  font-family: var(--fxch-body);
  color: var(--fxch-text);
}

/* Base panel */
.fxch-panel {
  position: absolute;
  padding: 0;
  max-width: 600px;
  opacity: 0;
  will-change: opacity;
}

/* Hero: left, vertically centred */
.fxch-panel--hero {
  left: 7vw;
  top: 50%;
  transform: translateY(-50%);
  pointer-events: auto;
}

/* Problem: right side */
.fxch-panel--problem {
  right: 6vw;
  top: 50%;
  transform: translateY(-50%);
  max-width: 420px;
}

/* Features: left side */
.fxch-panel--features {
  left: 7vw;
  top: 50%;
  transform: translateY(-50%);
}

/* Stats: right */
.fxch-panel--stats {
  right: 6vw;
  top: 50%;
  transform: translateY(-50%);
  max-width: 360px;
}

/* CTA: bottom centre */
.fxch-panel--cta {
  left: 50%;
  bottom: 9vh;
  transform: translateX(-50%);
  text-align: center;
  max-width: 620px;
  pointer-events: auto;
}

/* Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ TYPOGRAPHY Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ */
.fxch-eyebrow {
  font-family: var(--fxch-body);
  font-size: clamp(13px, 1.35vw, 17px);
  font-weight: 600;
  letter-spacing: .32em;
  text-transform: uppercase;
  color: var(--fxch-accent);
  margin: 0 0 22px; /* more air after FLOORX */
  text-shadow: 0 2px 4px rgba(0,0,0,0.9);
}
.fxch-eyebrow-logo {
  max-width: clamp(250px, 40vw, 450px);
  height: auto;
  margin-top: -60px;
  margin-bottom: 20px;
  display: block;
}

.fxch-headline {
  font-family: var(--fxch-display);
  font-size: clamp(2rem, 5vw, 4.5rem);
  line-height: .92; /* breathe — less compressed */
  letter-spacing: -.02em;
  color: var(--fxch-text);
  margin: 0 0 28px;
  display: flex;
  flex-direction: column;
  gap: 0.06em; /* ~4–8px between lines */
  text-shadow:
    0 0 60px rgba(125,249,255,.22),
    0 4px 40px rgba(0,0,0,.5);
}

.fxch-headline span {
  display: block;
}

.fxch-headline__outline {
  color: transparent;
  -webkit-text-stroke: 2.5px var(--fxch-accent);
  filter: drop-shadow(0 0 32px rgba(125,249,255,.45));
}

.fxch-subheading {
  font-size: clamp(1.125rem, 2vw, 1.55rem);
  font-weight: 500;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.95);
  margin: 0 0 32px;
  max-width: 30ch;
  text-shadow: 0 2px 6px rgba(0,0,0,0.9), 0 0 16px rgba(0,0,0,0.8);
}

.fxch-section-title {
  font-family: var(--fxch-display);
  font-size: clamp(2.25rem, 4.5vw, 3.75rem);
  line-height: 1.04;
  color: var(--fxch-text);
  margin: 0 0 28px;
