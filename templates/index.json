    "collapsible_content_HpigYC": {
      "type": "collapsible-content",
      "blocks": {
        "collapsible_row_ANVqTh": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Is FloorX safe for treadmills?",
            "icon": "question_mark",
            "row_content": "<p>Yes. FloorX is safe to use on treadmill belts and gym machines when used as directed.</p>",
            "page": ""
          }
        },
        "collapsible_row_Tw4Jr6": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Can FloorX be used on rubber gym floors?",
            "icon": "question_mark",
            "row_content": "<p>Yes. The product is designed to work on rubber gym flooring and help keep it clean and looking better.</p>",
            "page": ""
          }
        },
        "collapsible_row_pMqKTW": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How often should FloorX be used?",
            "icon": "question_mark",
            "row_content": "<p>In most gyms, using FloorX once every 30 days is enough to maintain a clean appearance.</p>",
            "page": ""
          }
        },
        "collapsible_row_U67k8A": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Does the product damage treadmill belts?",
            "icon": "question_mark",
            "row_content": "<p>No. FloorX has been tested on treadmills for more than 2 years to ensure it is safe when used correctly.</p>",
            "page": ""
          }
        },
        "collapsible_row_j9eKf9": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Can the product remove shoe marks and fingerprints?",
            "icon": "question_mark",
            "row_content": "<p>FloorX helps reduce the appearance of shoe marks and fingerprints that commonly appear on treadmill belts and rubber floors.</p>",
            "page": ""
          }
        },
        "collapsible_row_PYzbdc": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Do I need special equipment to use FloorX?",
            "icon": "question_mark",
            "row_content": "<p>No special tools are needed. A mop or a clean cloth with the prepared solution is enough</p>",
            "page": ""
          }
        },
        "collapsible_row_wpTRmc": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Where can I use FloorX?",
            "icon": "question_mark",
            "row_content": "<p>The product can be used on treadmill belts, rubber gym floors, and some gym machine surfaces.</p>",
            "page": ""
          }
        }
      },
