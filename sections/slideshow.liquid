{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-slideshow.css' | asset_url | stylesheet_tag }}
{%- if section.settings.slide_height == 'adapt_image' and section.blocks.first.settings.image != blank -%}
  {%- style -%}
    @media screen and (max-width: 749px) {
      #Slider-{{ section.id }}::before,
      #Slider-{{ section.id }} .media::before,
      #Slider-{{ section.id }}:not(.banner--mobile-bottom) .banner__content::before {
        padding-bottom: {{ 1 | divided_by: section.blocks.first.settings.image_mob.aspect_ratio | times: 100 }}%;
        content: '';
        display: block;
      }
    }

    @media screen and (min-width: 750px) {
      #Slider-{{ section.id }}::before,
      #Slider-{{ section.id }} .media::before {
        padding-bottom: {{ 1 | divided_by: section.blocks.first.settings.image.aspect_ratio | times: 100 }}%;
        content: '';
        display: block;
      }
    }
  {%- endstyle -%}
{%- endif -%}
{% if section.settings.layout == 'grid' %}
  <style>
      .slideshow-{{ section.id }} {
        border-radius: {{section.settings.banner_border}}px;
    }
  </style>
{% endif %}

<style>
    .lumin-slide {
       z-index:2;
       margin-top: 5px;
       max-width: 240px;
       left: calc(50% - 120px);
      {% if section.settings.hide_navigation %} display:none !important;{% endif %}
           }
  @media screen and (max-width: 749px){
    .lumin-slide {
       max-width: 100%;
       left: 0;
           }
  }
   .lumin-slide .slider-button {
       height:40px;
           }
</style>

<slideshow-component
  class="fx-hero slider-mobile-gutter{% if section.settings.layout == 'grid' %} page-width{% endif %}{% if section.settings.show_text_below %} mobile-text-below{% endif %}"
  role="region"
  aria-roledescription="{{ 'sections.slideshow.carousel' | t }}"
  aria-label="{{ section.settings.accessibility_info | escape }}"
  data-fx-hero
>
  {%- if section.settings.auto_rotate and section.blocks.size > 1 -%}
    <div class="slideshow__controls slideshow__controls--top lumin-slide slider-buttons no-js-hidden{% if section.settings.show_text_below %} slideshow__controls--border-radius-mobile{% endif %}">
      <button
        type="button"
        class="slider-button slider-button--prev"
        name="previous"
        aria-label="{{ 'sections.slideshow.previous_slideshow' | t }}"
        aria-controls="Slider-{{ section.id }}"
      >
        {% render 'icon-arro' %}
      </button>
      <div class="slider-counter slider-counter--{{ section.settings.slider_visual }}{% if section.settings.slider_visual == 'counter' or section.settings.slider_visual == 'numbers' %} caption{% endif %}">
        {%- if section.settings.slider_visual == 'counter' -%}
          <span class="slider-counter--current">1</span>
          <span aria-hidden="true"> / </span>
          <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
          <span class="slider-counter--total">{{ section.blocks.size }}</span>
        {%- else -%}
          <div class="slideshow__control-wrapper">
            {%- for block in section.blocks -%}
              <button
                class="slider-counter__link slider-counter__link--{{ section.settings.slider_visual }} link"
                aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
                aria-controls="Slider-{{ section.id }}"
              >
                {%- if section.settings.slider_visual == 'numbers' -%}
                  {{ forloop.index -}}
                {%- else -%}
                  <span class="dot"></span>
                {%- endif -%}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
      <button
        type="button"
        class="slider-button slider-button--next"
        name="next"
        aria-label="{{ 'sections.slideshow.next_slideshow' | t }}"
        aria-controls="Slider-{{ section.id }}"
      >
        {% render 'icon-arro' %}
      </button>

      {%- if section.settings.auto_rotate -%}
        <button
          type="button"
          class="slideshow__autoplay slider-button no-js-hidden{% if section.settings.auto_rotate == false %} slideshow__autoplay--paused{% endif %}"
          aria-label="{{ 'sections.slideshow.pause_slideshow' | t }}"
        >
          {%- render 'icon-pause' -%}
          {%- render 'icon-play' -%}
        </button>
      {%- endif -%}
    </div>
    <noscript>
      <div class="slider-buttons">
        <div class="slider-counter">
          {%- for block in section.blocks -%}
            <a
              href="#Slide-{{ section.id }}-{{ forloop.index }}"
              class="slider-counter__link link"
              aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
            >
              {{ forloop.index }}
            </a>
          {%- endfor -%}
        </div>
      </div>
    </noscript>
  {%- endif -%}

  <div
    class="slidshow-{{ section.id }} slideshow banner banner--{{ section.settings.slide_height }} grid grid--1-col slider slider--everywhere{% if section.settings.show_text_below %} banner--mobile-bottom{% endif %}{% if section.blocks.first.settings.image == blank %} slideshow--placeholder{% endif %}"
    id="Slider-{{ section.id }}"
    aria-live="polite"
    aria-atomic="true"
    data-autoplay="{{ section.settings.auto_rotate }}"
    data-speed="{{ section.settings.change_slides_speed }}"
    {% if section.settings.layout == 'grid' %}
      style="border-radius:{{section.settings.banner_border}}px;"
    {% endif %}
  >
    {%- for block in section.blocks -%}
      <style>
        #Slide-{{ section.id }}-{{ forloop.index }} .banner__media::after {
          opacity: {{ block.settings.image_overlay_opacity | divided_by: 100.0 }};
        }
      </style>
      <div
        class="slideshow__slide grid__item grid--1-col slider__slide"
        id="Slide-{{ section.id }}-{{ forloop.index }}"
        {% if block.settings['link-2'] %}
          onclick="location.href='{{ block.settings.link-2  }}';" style="cursor: pointer;"
        {% endif %}
        {{ block.shopify_attributes }}
        role="group"
        aria-roledescription="{{ 'sections.slideshow.slide' | t }}"
        aria-label="{{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
        tabindex="-1"
      >
        <div class="small-hide">
          <div class="slideshow__media banner__media media{% if block.settings.image == blank %} placeholder{% endif %}">
            {%- if block.settings.image -%}
              {%- assign height = block.settings.image.width | divided_by: block.settings.image.aspect_ratio | round -%}
              {%
                    render 'responsive-image' with
                    image: block.settings.image,
                    image_class: "image",
                    wrapper_class: "image-wrapper"
                  %}
                {%- else -%}
               {% render 'lumin-placeholder' %}
                  
                {%- endif -%}
            {% comment %}
                
              {{
                block.settings.image
                | image_url: width: 3840
                | image_tag:
                  loading: 'lazy',
                  height: height,
                  sizes: '100vw',
                  widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
              }}
            {%- else -%}
              {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
              {% endcomment %}
            
          </div>
        </div>
        <div class="large-up-hide">
          <div class="slideshow__media banner__media media{% if block.settings.image_mob == blank %} placeholder{% endif %}">
            {%- if block.settings.image_mob -%}
              {%- assign height = block.settings.image_mob.width
                | divided_by: block.settings.image_mob.aspect_ratio
                | round
              -%}
              {{
                block.settings.image_mob
                | image_url: width: 3840
                | image_tag:
                  loading: 'lazy',
                  height: height,
                  sizes: '100vw',
                  widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
              }}
            {%- else -%}
              {% render 'lumin-placeholder' %}
            {%- endif -%}
          </div>
        </div>
        <div class="slideshow__text-wrapper banner--content-align-mobile-bottom banner__content banner__content--{{ block.settings.mobile_box_align }} banner__content--{{ block.settings.box_align }} page-width{% if block.settings.show_text_box == false %} banner--desktop-transparent{% endif %}">
          <div class="slideshow__text banner__box banner__box-{{block.id}}  content-container content-container--full-width-mobile color-{{ block.settings.color_scheme }} gradient slideshow__text--{{ block.settings.text_alignment }} slideshow__text-mobile--{{ block.settings.text_alignment_mobile }}">
            {%- if block.settings.caption != blank -%}
              <p
                class="inline-richtext h2"
                style="font-size:{{ block.settings.block_cap_size }}px;color:{{ block.settings.cap_color }};margin: 0"
              >
                {{ block.settings.caption | replace: '[', '<span class="lumin-text__fancy1">' | replace: ']', '</span>' | replace: '((', '<span class="lumin-text__fancy2">' | replace: '))', '</span>' }}
              </p>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <style>
                .lm-slide-head-{{block.id}} {
                    font-size:{{ block.settings.block_head_size-2 }}px !important;
                    line-height:{{ block.settings.block_head_line }};
                    margin-bottom:10px;
                }
                  @media screen and (max-width: 600px){
                    .lm-slide-head-{{block.id}} {
                    font-size:{{ block.settings.block_head_size-mobile }}px !important;
                }
                  }
                          @media only screen and (max-width: 749px) {
                   .banner__content--flex-start>.banner__box-{{block.id}} {
                    margin: {{block.settings.mobile_text_spacing}}px 0;
                  }
                          }
              </style>
              <h2 class="banner__heading inline-richtext lm-slide-head-{{block.id}} {{ block.settings.block_head_size }}">
                {{ block.settings.heading | replace: '[', '<span class="lumin-text__fancy1">' | replace: ']', '</span>' | replace: '((', '<span class="lumin-text__fancy2">' | replace: '))', '</span>' }}
              </h2>
            {%- endif -%}
            {%- if block.settings.subheading != blank -%}
              <div class="banner__text" {{ block.shopify_attributes }}>
                <span>{{ block.settings.subheading | replace: '[', '<span class="lumin-text__fancy1">' | replace: ']', '</span>' | replace: '((', '<span class="lumin-text__fancy2">' | replace: '))', '</span>' }}</span>
              </div>
            {%- endif -%}
            {%- if block.settings.button_label != blank -%}
              <div class="banner__buttons">
                <a
                  {% if block.settings.link %}
                    href="{{ block.settings.link }}"
                  {% else %}
                    role="link" aria-disabled="true"
                  {% endif %}
                  class="button {% if block.settings.button_style_secondary %}button--secondary{% else %}button--primary{% endif %}"
                >
                  {{- block.settings.button_label | escape -}}
                </a>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 and section.settings.auto_rotate == false -%}
    <div class="slideshow__controls slider-buttons lumin-slide no-js-hidden{% if section.settings.show_text_below %} slideshow__controls--border-radius-mobile{% endif %}">
      <button
        type="button"
        class="slider-button slider-button--prev"
        name="previous"
        aria-label="{{ 'sections.slideshow.previous_slideshow' | t }}"
        aria-controls="Slider-{{ section.id }}"
      >
        {% render 'icon-arro' %}
      </button>
      <div class="slider-counter slider-counter--{{ section.settings.slider_visual }}{% if section.settings.slider_visual == 'counter' or section.settings.slider_visual == 'numbers' %} caption{% endif %}">
        {%- if section.settings.slider_visual == 'counter' -%}
          <span class="slider-counter--current">1</span>
          <span aria-hidden="true"> / </span>
          <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
          <span class="slider-counter--total">{{ section.blocks.size }}</span>
        {%- else -%}
          <div class="slideshow__control-wrapper">
            {%- for block in section.blocks -%}
              <button
                class="slider-counter__link slider-counter__link--{{ section.settings.slider_visual }} link"
                aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
                aria-controls="Slider-{{ section.id }}"
              >
                {%- if section.settings.slider_visual == 'numbers' -%}
                  {{ forloop.index -}}
                {%- else -%}
                  <span class="dot"></span>
                {%- endif -%}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
      <button
        type="button"
        class="slider-button slider-button--next"
        name="next"
        aria-label="{{ 'sections.slideshow.next_slideshow' | t }}"
        aria-controls="Slider-{{ section.id }}"
      >
        {% render 'icon-arro' %}
      </button>

      {%- if section.settings.auto_rotate -%}
        <button
          type="button"
          class="slideshow__autoplay slider-button no-js-hidden{% if section.settings.auto_rotate == false %} slideshow__autoplay--paused{% endif %}"
          aria-label="{{ 'sections.slideshow.pause_slideshow' | t }}"
        >
          {%- render 'icon-pause' -%}
          {%- render 'icon-play' -%}
        </button>
      {%- endif -%}
    </div>
    <noscript>
      <div class="slider-buttons">
        <div class="slider-counter">
          {%- for block in section.blocks -%}
            <a
              href="#Slide-{{ section.id }}-{{ forloop.index }}"
              class="slider-counter__link link"
              aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
            >
              {{ forloop.index }}
            </a>
          {%- endfor -%}
        </div>
      </div>
    </noscript>
  {%- endif -%}
</slideshow-component>

{%- if request.design_mode -%}
  <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- comment -%} FloorX Hero Enhancement Styles — Full Cinematic Treatment {%- endcomment -%}
<style>
  /* =====================================================
     HERO — FULL BLEED OVERRIDE
     Force hero to always be 100vw regardless of Shopify
     section layout settings (grid vs full_bleed).
     ===================================================== */
  .fx-hero.slideshow-component,
  .fx-hero.slideshow-component.page-width,
  .fx-hero.slider-mobile-gutter {
    max-width: 100% !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
    width: 100% !important;
  }

  .fx-hero.slideshow-component {
    position: relative;
    overflow: hidden;
    background: #060810;
    display: block;
  }

  .fx-hero .slideshow {
    position: relative;
    width: 100%;
    min-height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .fx-hero .banner--adapt,
  .fx-hero .banner {
    min-height: 100vh !important;
  }

  .fx-hero .slideshow__slide,
  .fx-hero .slider__slide {
    position: relative;
    min-height: 100vh;
    background: linear-gradient(135deg, #060810 0%, #080A12 50%, #0B1120 100%);
  }

  /* =====================================================
     BANNER MEDIA — Full-fill background image
     ===================================================== */
  .fx-hero .banner__media,
  .fx-hero .slideshow__media {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    height: 100% !important;
    overflow: hidden;
  }

  .fx-hero .banner__media img,
  .fx-hero .slideshow__media img,
  .fx-hero .banner__media .image,
  .fx-hero .image-wrapper,
  .fx-hero .image-wrapper img {
    width: 100% !important;
    height: 100% !important;
    max-width: none !important;
    object-fit: cover !important;
    object-position: center center;
    display: block;
  }

  /* Cinematic vignette gradient over the hero image */
  .fx-hero .banner__media::after,
  .fx-hero .slideshow__media::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right,
        rgba(6, 8, 16, 0.82) 0%,
        rgba(6, 8, 16, 0.5) 50%,
        rgba(6, 8, 16, 0.15) 100%
      ),
      linear-gradient(to bottom,
        rgba(6, 8, 16, 0.25) 0%,
        transparent 30%,
        transparent 65%,
        rgba(6, 8, 16, 0.7) 100%
      );
    z-index: 2;
    pointer-events: none;
  }

  /* =====================================================
     AMBIENT ORBS — CSS depth lighting
     ===================================================== */
  .fx-hero .slideshow::before {
    content: '';
    position: absolute;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(37, 99, 235, 0.2) 0%, transparent 70%);
    top: -10%;
    left: -5%;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    z-index: 3;
    animation: fx-orb-1 12s ease-in-out infinite;
  }

  .fx-hero .slideshow::after {
    content: '';
    position: absolute;
    width: 450px;
    height: 450px;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.14) 0%, transparent 70%);
    bottom: 5%;
    right: 5%;
    border-radius: 50%;
    filter: blur(70px);
    pointer-events: none;
    z-index: 3;
    animation: fx-orb-2 16s ease-in-out infinite;
  }

  @keyframes fx-orb-1 {
    0%, 100% { transform: translate(0, 0); }
    40% { transform: translate(40px, 25px); }
    70% { transform: translate(-20px, 35px); }
  }

  @keyframes fx-orb-2 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-35px, -25px); }
  }

  /* Light beam sweep */
  .fx-hero .slideshow__slide::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -100%;
    width: 300%;
    height: 300%;
    background: linear-gradient(
      125deg,
      transparent 42%,
      rgba(59, 130, 246, 0.05) 50%,
      transparent 58%
    );
    z-index: 4;
    pointer-events: none;
    animation: fx-beam 14s ease-in-out infinite;
  }

  @keyframes fx-beam {
    0%   { transform: translateX(-30%); opacity: 0; }
    10%  { opacity: 1; }
    90%  { opacity: 1; }
    100% { transform: translateX(130%); opacity: 0; }
  }

  /* =====================================================
     HERO CONTENT — always above image layers
     ===================================================== */
  .fx-hero .slideshow__text-wrapper,
  .fx-hero .banner__content {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    min-height: 100vh;
  }

  .fx-hero .slideshow__text,
  .fx-hero .banner__box {
    position: relative;
    z-index: 10;
    background: transparent !important;
  }

  .fx-hero .banner__heading {
    font-family: 'Manrope', -apple-system, sans-serif;
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: #FFFFFF;
    text-shadow: 0 4px 40px rgba(0, 0, 0, 0.6);
    margin-bottom: 1rem;
  }

  .fx-hero .lumin-text__fancy1 {
    background: linear-gradient(135deg, #60A5FA 0%, #2563EB 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .fx-hero .lumin-text__fancy2 {
    background: linear-gradient(135deg, #FFFFFF 0%, #60A5FA 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .fx-hero .inline-richtext.h2 {
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.75rem;
    color: #60A5FA;
    margin-bottom: 1.25rem;
    display: block;
  }

  .fx-hero .banner__text,
  .fx-hero .banner__text span {
    font-family: 'Manrope', sans-serif;
    font-weight: 400;
    color: #A8B3C5;
    font-size: 1.1rem;
    line-height: 1.7;
  }

  .fx-hero .banner__box > * + * { margin-top: 1.25rem; }

  /* =====================================================
     CTA BUTTONS
     ===================================================== */
  .fx-hero .banner__buttons {
    margin-top: 2rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .fx-hero .button--primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: linear-gradient(135deg, #2563EB 0%, #3B82F6 100%);
    color: #FFFFFF !important;
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    border: none;
    border-radius: 12px;
    padding: 0.9rem 2rem;
    box-shadow: 0 4px 24px rgba(37, 99, 235, 0.4);
    transition: all 250ms cubic-bezier(0.16, 1, 0.3, 1);
    text-decoration: none;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .fx-hero .button--primary::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
    opacity: 0;
    transition: opacity 250ms ease;
  }

  .fx-hero .button--primary:hover::after { opacity: 1; }
  .fx-hero .button--primary:hover {
    box-shadow: 0 6px 36px rgba(37, 99, 235, 0.6);
    transform: translateY(-2px);
    color: #FFFFFF !important;
  }

  .fx-hero .button--secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(11, 17, 32, 0.55);
    color: #FFFFFF !important;
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    border: 1px solid rgba(59, 130, 246, 0.35);
    border-radius: 12px;
    padding: 0.9rem 2rem;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    transition: all 250ms cubic-bezier(0.16, 1, 0.3, 1);
    text-decoration: none;
    cursor: pointer;
  }

  .fx-hero .button--secondary:hover {
    border-color: rgba(59, 130, 246, 0.65);
    background: rgba(11, 17, 32, 0.85);
    box-shadow: 0 4px 20px rgba(37, 99, 235, 0.25);
  }

  /* =====================================================
     SLIDER CONTROLS
     ===================================================== */
  .fx-hero .slider-button {
    background: rgba(11, 17, 32, 0.55);
    border: 1px solid rgba(59, 130, 246, 0.3);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 50%;
    color: #FFFFFF;
    transition: all 250ms ease;
  }

  .fx-hero .slider-button:hover {
    background: rgba(37, 99, 235, 0.4);
    border-color: rgba(59, 130, 246, 0.7);
    box-shadow: 0 0 16px rgba(37, 99, 235, 0.4);
  }

  .fx-hero .dot {
    background: rgba(255, 255, 255, 0.35);
    border: 1px solid rgba(255, 255, 255, 0.2);
    transition: all 250ms ease;
  }

  /* =====================================================
     MOBILE
     ===================================================== */
  @media (max-width: 749px) {
    .fx-hero .slideshow,
    .fx-hero .banner--adapt,
    .fx-hero .banner,
    .fx-hero .slideshow__slide,
    .fx-hero .slideshow__text-wrapper,
    .fx-hero .banner__content {
      min-height: 85vh !important;
    }

    .fx-hero .banner__heading {
      font-size: clamp(1.75rem, 8vw, 2.5rem) !important;
    }

    .fx-hero .banner__text { font-size: 0.9375rem; }

    .fx-hero .button--primary,
    .fx-hero .button--secondary {
      padding: 0.8rem 1.5rem;
      font-size: 0.9375rem;
    }

    .fx-hero .banner__buttons {
      flex-direction: column;
      align-items: flex-start;
    }

    .fx-hero .slideshow::before { width: 300px; height: 300px; }
    .fx-hero .slideshow::after  { width: 220px; height: 220px; }
  }

  /* =====================================================
     REDUCED MOTION
     ===================================================== */
  @media (prefers-reduced-motion: reduce) {
    .fx-hero .slideshow::before,
    .fx-hero .slideshow::after,
    .fx-hero .slideshow__slide::before {
      animation: none !important;
    }
  }
</style>


