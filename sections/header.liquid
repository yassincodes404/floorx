            /* --- INLINE EXPANDING SEARCH --- */
  
  body.overflow-hidden {
    overflow: auto !important;
  }
  
  /* Make sure the icons container can expand normally */
  .header__icons {
    position: relative !important;
    align-items: center !important;
    transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
  }
  
  .header__search {
    position: relative !important;
    display: flex;
    align-items: center !important;
    margin: 0 !important;
  }
  
  /* The <details> element controls the physical width in the flex layout */
  .header__search details {
    position: relative !important;
    display: flex;
    align-items: center !important;
    width: 44px !important;
    height: 44px !important; justify-content: center !important;
    transition: width 0.35s cubic-bezier(0.4, 0, 0.2, 1) !important;
    will-change: width;
  }
  
  /* When open, push elements by expanding physical width */
  @media screen and (min-width: 990px) {
    .header__search details[open] {
      width: clamp(250px, 20vw, 350px) !important;
    }
  }
  @media screen and (max-width: 989px) {
    .header__search details[open] {
      width: 250px !important;
    }
  }
  
  /* Fade out the original search icon seamlessly */
  .header__search details > summary {
    transition: opacity 0.15s ease !important;
    opacity: 1;
    z-index: 10;
  }
  .header__search details[open] > summary {
    opacity: 0 !important;
    pointer-events: none !important;
    visibility: hidden !important;
  }
  
  /* Hide all children of summary when open to prevent icon duplication */
  .header__search details[open] > summary *,
  .header__search details[open] > summary span,
  .header__search details[open] > summary svg {
    opacity: 0 !important;
    visibility: hidden !important;
  }
  
  /* The wrapper perfectly fills the expanding details container */
  .search-modal {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    height: 100% !important;
    background: transparent !important;
    z-index: 999 !important;
    pointer-events: none;
    border: none !important;
    opacity: 0 !important;
    visibility: hidden;
    transition: opacity 0.2s ease 0.05s !important;
  }
  
  details[open] > .search-modal {
    pointer-events: auto;
    visibility: visible;
    opacity: 1 !important;
  }
  
  .search-modal .modal-overlay {
    display: none !important;
  }

  .search-modal__content {
    background: transparent !important;
    border: none !important;
    padding: 0 !important;
    margin: 0 !important;
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    height: 100% !important;
    box-shadow: none !important;
  }

  /* The actual input pill wrapper */
  .search-modal__form .field {
    background: rgba(11, 17, 32, 0.95) !important;
    backdrop-filter: blur(24px) !important;
    -webkit-backdrop-filter: blur(24px) !important;
    border: 1px solid rgba(59, 130, 246, 0.25) !important;
    border-radius: 9999px !important;
    height: 44px !important; justify-content: center !important;
    width: 100% !important;
    box-sizing: border-box !important;
    display: flex !important;
    align-items: center !important;
    box-shadow: 0 10px 30px rgba(0,0,0,0.3) !important;
  }

  /* Input text field */
  .search-modal .search__input,
  input[name="q"] {
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
    color: #FFFFFF !important;
    font-family: 'Manrope', sans-serif !important;
    font-size: 1.05rem !important;
    font-weight: 400 !important;
    padding: 0 50px 0 20px !important;
    box-sizing: border-box !important;
    height: 100% !important;
    width: 100% !important;
    margin: 0 !important;
    caret-color: #3B82F6;
  }

  /* Predictive search dropdown stays absolute so it drops below header */
  .predictive-search {
    background: rgba(11, 17, 32, 0.95) !important;
    backdrop-filter: blur(24px) !important;
    -webkit-backdrop-filter: blur(24px) !important;
    border: 1px solid rgba(59, 130, 246, 0.2) !important;
    border-radius: 20px !important;
    position: absolute !important;
    top: calc(100% + 15px) !important;
    left: 0 !important;
    width: 100% !important;
    box-sizing: border-box !important;
    box-shadow: 0 20px 50px rgba(0,0,0,0.5) !important;
    overflow: hidden !important;
    margin-top: 0 !important;
  }
  
  /* The new search icon correctly balanced inside the pill */
  .search-modal__form .search__button {
    position: absolute !important;
    right: 18px !important;
    top: 50% !important;
    transform: translateY(-50%) !important;
    height: 100% !important;
    width: auto !important;
    padding: 0 !important;
    margin: 0 !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    color: rgba(255, 255, 255, 0.6) !important;
    background: transparent !important;
    border: none !important;
    box-sizing: border-box !important;
  }
  
  .search-modal__close-button {
    display: none !important;
  }
  
  .search-modal__form {
    margin: 0 !important;
    width: 100% !important;
    height: 100% !important;
    box-sizing: border-box !important;
  }
  /* Force search to stay in the icons row regardless of logo position */
  @media screen and (min-width: 990px) {
    header.header > .header__search {
      display: none !important;
    }
    .header__icons > .header__search {
      display: flex !important;
    }
  }
  /* Remove native Dawn field outlines and backgrounds to prevent square artifacts */
  .search-modal__form .field:after,
  .search-modal__form .field:before {
    display: none !important;
    content: none !important;
    opacity: 0 !important;
    box-shadow: none !important;
    border: none !important;
    background: transparent !important;
  }
  
  .search-modal__form .field {
    overflow: hidden !important;
    /* Ensure no square background leaks */
    background-clip: padding-box !important;
  }
  /* Make the standalone search icon integrate perfectly */
  .header__icon--summary {
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
    border-radius: 0 !important;
    padding: 0 !important;
  }
  .header__icon--summary::after,
  .header__icon--summary::before {
    display: none !important;
  }
  /* =========================================================
     CINEMATIC HEADER OVERRIDES
     Forces fixed positioning and matches the 3D aesthetic
     ========================================================= */
  .section-header, 
  .shopify-section-header-sticky, 
  sticky-header, 
  .header-wrapper, 
  .header, 
  .header-wrapper::before, 
  .header-wrapper::after,
  .header::before,
  .header::after,
  .shopify-section-group-header-group {
    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
    border: none !important;
    box-shadow: none !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
  }
  
  .shopify-section-group-header-group {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    z-index: 9999 !important;
  }

  .section-header {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    z-index: 9999 !important;
    margin-bottom: 0 !important;
    margin-top: 0 !important;
  }
  
  /* Nav type/icon sizes owned by floorx-header.css — do not override here */
  .fx-nav-svg {
    width: 18px;
    height: 18px;
    vertical-align: middle;
    transform: translateY(-2px);
  }
</style>
