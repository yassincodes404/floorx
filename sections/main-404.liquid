{{ 'fx-collection.css' | asset_url | stylesheet_tag }}

<style>
  .fx-404 {
    position: relative;
    min-height: min(70vh, 640px);
    display: grid;
    place-items: center;
    padding: clamp(6rem, 12vw, 8rem) 1.25rem 4rem;
    text-align: center;
    font-family: var(--fx-font-ui, "Space Grotesk", system-ui, sans-serif);
    color: #fff;
    background: transparent;
  }

  .fx-404__inner {
    width: min(560px, 100%);
    margin: 0 auto;
    padding: clamp(1.5rem, 3vw, 2.25rem);
    border-radius: 20px;
    border: 1px solid rgba(0, 207, 255, 0.2);
    background:
      linear-gradient(180deg, rgba(26, 26, 26, 0.55) 0%, rgba(10, 10, 10, 0.78) 100%);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    box-shadow:
      0 0 0 1px rgba(0, 170, 255, 0.04) inset,
      0 24px 60px rgba(0, 0, 0, 0.35);
  }

  .fx-404__code {
    margin: 0 0 0.65rem;
    font-family: var(--fx-font-display, Anton, Impact, sans-serif);
    font-size: clamp(3.5rem, 12vw, 5.5rem);
    font-weight: 400;
    letter-spacing: 0.04em;
    line-height: 1;
    color: #00cfff;
    text-shadow: 0 0 40px rgba(0, 170, 255, 0.35);
  }

  .fx-404__title {
    margin: 0 0 0.75rem;
    font-size: var(--fx-type-h2, clamp(1.45rem, 2.4vw, 1.95rem));
    font-weight: 700;
    letter-spacing: -0.01em;
    color: #fff;
  }

  .fx-404__text {
    margin: 0 0 1.5rem;
    font-size: var(--fx-type-body-sm, 1.05rem);
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.65);
  }

  .fx-404__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .fx-404__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    min-height: 48px;
    padding: 0.75rem 1.35rem;
    border-radius: 12px;
    font-size: var(--fx-type-btn, 0.9rem);
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none !important;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .fx-404__btn--primary {
    background: linear-gradient(90deg, #00cfff, #00aaff);
    color: #0a0a0a !important;
    border: none;
    box-shadow: 0 10px 28px rgba(0, 170, 255, 0.3);
  }

  .fx-404__btn--primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 14px 36px rgba(0, 207, 255, 0.38);
  }

  .fx-404__btn--ghost {
    background: transparent;
    color: #fff !important;
    border: 1px solid rgba(0, 207, 255, 0.4);
  }

  .fx-404__btn--ghost:hover {
    border-color: #00cfff;
    background: rgba(0, 170, 255, 0.1);
  }
</style>

<div class="fx-404">
  <div class="fx-404__inner">
    <p class="fx-404__code" aria-hidden="true">404</p>
    <h1 class="fx-404__title">{{ 'templates.404.title' | t | default: 'Page not found' }}</h1>
    <p class="fx-404__text">
      {{ 'templates.404.subtext' | t | default: 'The page you requested does not exist.' }}
    </p>
    <div class="fx-404__actions">
      <a class="fx-404__btn fx-404__btn--primary" href="{{ routes.root_url }}">{{ 'floorx.common.home' | t }}</a>
      <a class="fx-404__btn fx-404__btn--ghost" href="{{ routes.all_products_collection_url }}">
        {{ 'general.continue_shopping' | t | default: 'Continue shopping' }}
      </a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "404",
  "tag": "section",
  "class": "section-main-404",
  "settings": []
}
{% endschema %}
