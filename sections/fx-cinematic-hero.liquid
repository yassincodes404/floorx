<!-- GSAP + ScrollTrigger (cdnjs — already whitelisted in Shopify) -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer="defer"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer="defer"></script>

<!-- ══════════════ MAIN SCRIPT ══════════════ -->
<script>
function FXCinematicHero() {
  'use strict';

  const SID     = '{{ sid }}';
  const GLB_URL = '{{ glb_url }}';

  /* ── Safety: dismiss loader after 20s regardless ── */
  var _safetyTimer = setTimeout(function () {
    _hideLoader();
    _showHeroFallback();
  }, 20000);

  function _hideLoader() {
    var el = document.getElementById('fxch-load-' + SID);
    if (el) {
      el.classList.add('is-hidden');
      el.setAttribute('hidden', '');
      el.style.display = 'none';
    }
    clearTimeout(_safetyTimer);
  }
  /* Never show secondary FLOORX loader after site preloader */
  _hideLoader();
  function _showHeroFallback() {
    var hp = document.getElementById('fxch-hero-' + SID);
    if (hp) { hp.style.opacity = '1'; hp.style.pointerEvents = 'auto'; }
    var ind = document.getElementById('fxch-ind-' + SID);
    if (ind) ind.style.opacity = '1';
  }

  /* ── Guard: Three.js must be loaded ────────────────────── */
  if (typeof THREE === 'undefined' || typeof THREE.GLTFLoader === 'undefined') {
    console.warn('[FloorX Hero] Three.js / GLTFLoader not available — showing fallback');
    setTimeout(function () { _hideLoader(); _showHeroFallback(); }, 800);
    return;
  }

  /* ── Guard: GSAP must be loaded ────────────────────────── */
  if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
    console.warn('[FloorX Hero] GSAP not available — showing fallback');
    setTimeout(function () { _hideLoader(); _showHeroFallback(); }, 800);
    return;
  }
  gsap.registerPlugin(ScrollTrigger);

  /* Header stays ghost over the full cinematic hero — no glass-on-scroll */

  var isMobile      = window.innerWidth < 768;
  
  /* ── Mobile Fallback: High-Res Static 3D ──────────────── */
  if (isMobile) {
    console.warn('[FloorX Hero] Mobile detected — using lightweight static 3D layout');
    _hideLoader();
    var hp = document.getElementById('fxch-hero-' + SID);
    var pProb = document.getElementById('fxch-prob-' + SID);
    var pFeat = document.getElementById('fxch-feat-' + SID);
    var pStats = document.getElementById('fxch-stats-' + SID);
    var pCta = document.getElementById('fxch-cta-' + SID);
    
    if (hp) { hp.style.opacity = '1'; hp.style.pointerEvents = 'auto'; }
    /* Force 3D properties to be instantly visible and centered */
    S.sceneOpacity = 1;
    S.btlOpacity = 1;
    S.btlScale = 1;
    S.btlX = 0;
    S.btlY = -0.15;
    S.opHero = 1;
    S.opProb = 1;
    S.opFeat = 1;
    S.opStats = 1;
    S.opCta = 1;
    
    /* DO NOT RETURN. Let WebGL load and render the bottle beautifully! */
  }

  var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ── DOM refs ────────────────────────────────────────────────────────── */
  var canvasEl  = document.getElementById('fxch-canvas-' + SID);

  var glowEl    = document.getElementById('fxch-glow-'   + SID);
  var glowMidEl = document.getElementById('fxch-glow-mid-' + SID);
  var glowCoreEl= document.getElementById('fxch-glow-core-' + SID);
  var shadowEl  = document.getElementById('fxch-shadow-' + SID);
  var pulseEl   = document.getElementById('fxch-pulse-'  + SID);
  var reflectEl = document.getElementById('fxch-ref-'    + SID);
  var scrollInd = document.getElementById('fxch-ind-'    + SID);
  var portalEl  = document.getElementById('fxch-portal-' + SID);
  var pHero     = document.getElementById('fxch-hero-'   + SID);
  var pProb     = document.getElementById('fxch-prob-'   + SID);
  var pFeat     = document.getElementById('fxch-feat-'   + SID);
  var pStats    = document.getElementById('fxch-stats-'  + SID);
  var pCta      = document.getElementById('fxch-cta-'    + SID);

  /* Animated state (GSAP animates this plain object) */
  var S = {
    sceneOpacity:    0,
    glowOpacity:     0,
    glowMid:         0,
    glowCore:        0,
    shadowOp:        0,
    reflectStrength: 0,
    pulseBoost:      0, /* 0–1 energy pulse intensity */
    portalOp:        0,
    portalScale:     0.72,
    portalX:         isMobile ? 50 : 58,
    portalY:         isMobile ? 48 : 50,
    portalRot:       0, /* deg — slight yaw with bottle travel */
    camZ:  5.55, camX: 0.0, camY: 0.05,
    /* Hero product position — larger bottle, slightly right of copy */
    btlX:  isMobile ? 0.02 : 0.42,
    btlY:  isMobile ? -0.2 : -0.55,
    btlZ:  -0.65,
    btlOpacity: 0,
    btlScale: 0.88,
    /* Scroll yaw: left = +, right = − (radians) */
    btlRotY: isMobile ? 0 : -0.18,
    btlRotZ: 0,
    rimInt: 0, keyInt: 0, ambInt: 0, topInt: 0,
    opHero: 0, opProb: 0, opFeat: 0, opStats: 0, opCta: 0, opInd: 0,
  };

  /* Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â
     THREE.JS SCENE SETUP
     Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â */
  var renderer, scene, camera;
  var ambLight, keyLight, fillLight, rimLight, rimLightB, topLight, hemiLight;
  var bottle = null;
  var contactShadow = null;
  var floor = null;
  var webglOK = false;
  /* 3D cube portal removed — CSS bloom only */

  try {
    renderer = new THREE.WebGLRenderer({
      canvas: canvasEl,
      antialias: !isMobile,
      alpha: true, /* transparent — page bg + light spill show through */
      powerPreference: 'high-performance',
      premultipliedAlpha: false,
    });
    var initW = window.innerWidth;
    var initH = window.innerHeight;

    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(initW, initH);
    renderer.setClearColor(0x000000, 0);
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    /* Slightly lower exposure so new bottle reads darker / richer */
    renderer.toneMappingExposure = 1.08;
    renderer.outputEncoding = THREE.sRGBEncoding;
    renderer.shadowMap.enabled = !isMobile;
    renderer.shadowMap.type = THREE.PCFSoftShadowMap;

    scene = new THREE.Scene();
    scene.background = null;
    scene.fog = null;

    camera = new THREE.PerspectiveCamera(32, initW / initH, 0.05, 80);
    camera.position.set(0, 0.05, 5.7);

    /* Cool low ambient — preserves dark body of bottle */
    ambLight = new THREE.AmbientLight(0x8a9bb8, 0);
    scene.add(ambLight);

    hemiLight = new THREE.HemisphereLight(0x4a6a9a, 0x050810, 0);
    scene.add(hemiLight);

    /* Key — soft cool white, not blown-out */
    keyLight = new THREE.DirectionalLight(0xd8e4f5, 0);
    keyLight.position.set(2.4, 4.6, 3.2);
    keyLight.castShadow = !isMobile;
    if (!isMobile) {
      keyLight.shadow.mapSize.set(2048, 2048);
      keyLight.shadow.bias = -0.0004;
      keyLight.shadow.normalBias = 0.02;
      keyLight.shadow.radius = 6;
      keyLight.shadow.camera.near = 0.5;
      keyLight.shadow.camera.far = 22;
      keyLight.shadow.camera.left = -6;
      keyLight.shadow.camera.right = 6;
      keyLight.shadow.camera.top = 6;
      keyLight.shadow.camera.bottom = -6;
    }
    scene.add(keyLight);

    /* Fill — muted cyan, keeps shadow side dark */
    fillLight = new THREE.PointLight(0x3d6db8, 0, 14);
    fillLight.position.set(-3.0, 0.2, 2.0);
    scene.add(fillLight);

    /* Rim A — electric edge only (not wash) */
    rimLight = new THREE.PointLight(0x7DF9FF, 0, 14);
    rimLight.position.set(-1.5, 1.1, -2.0);
    scene.add(rimLight);

    /* Rim B — deep blue silhouette edge */
    rimLightB = new THREE.PointLight(0x1e4a9a, 0, 12);
    rimLightB.position.set(1.9, 0.4, -1.7);
    scene.add(rimLightB);

    /* Top highlight — restrained specular sweep */
    topLight = new THREE.SpotLight(0xc8d8ec, 0, 12, Math.PI / 8, 0.6, 1.3);
    topLight.position.set(0.3, 4.0, 2.0);
    topLight.target.position.set(0.4, 0, 0);
    scene.add(topLight);
    scene.add(topLight.target);

    /* Soft contact shadow disc under bottle */
    var shadowMat = new THREE.MeshBasicMaterial({
      color: 0x000000,
      transparent: true,
      opacity: 0,
      depthWrite: false,
    });
    contactShadow = new THREE.Mesh(new THREE.CircleGeometry(0.72, 48), shadowMat);
    contactShadow.rotation.x = -Math.PI / 2;
    contactShadow.position.y = -1.55;
    scene.add(contactShadow);

    /* Floor plane — soft AO + receives key shadows from bottle */
    var floorMat = new THREE.MeshStandardMaterial({
      color: 0x040810,
      metalness: 0.15,
      roughness: 0.92,
      transparent: true,
      opacity: 0,
    });
    floor = new THREE.Mesh(new THREE.PlaneGeometry(14, 14), floorMat);
    floor.rotation.x = -Math.PI / 2;
    floor.position.y = -1.62;
    floor.receiveShadow = true;
    scene.add(floor);


    webglOK = true;
  } catch (e) {
    console.warn('[FloorX Hero] WebGL init failed:', e);
    _hideLoader();
    _showHeroFallback();
    return;
  }

  /* 3D cube portal fully removed — bottle GLB + CSS bloom only */

  /* Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â
     LOAD GLB MODEL
     Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â */
  var gltfLoader = new THREE.GLTFLoader();


  /* Timeout on model load: 25 seconds */
  var loadTimer = setTimeout(function () {
    console.warn('[FloorX Hero] GLB load timeout Ã¢â‚¬â€ showing fallback');
    _hideLoader();
    _showHeroFallback();
  }, 25000);

  gltfLoader.load(
    GLB_URL,
    function onGLBLoaded(gltf) {
      clearTimeout(loadTimer);

      bottle = gltf.scene;

      /* Auto-scale — larger hero product presence */
      var bbox = new THREE.Box3().setFromObject(bottle);
      var bSize = bbox.getSize(new THREE.Vector3());
      var maxDim = Math.max(bSize.x, bSize.y, bSize.z);
      var targetSize = isMobile ? 1.35 : 2.0;
      var scl = targetSize / maxDim;
      bottle.scale.setScalar(scl);
      bottle.userData.baseScale = scl;

      /* Centre on bounding-box centroid */
      var bCentre = bbox.getCenter(new THREE.Vector3());
      bottle.position.sub(bCentre.multiplyScalar(scl));
      bottle.position.z = S.btlZ;

      /* Shadows + fade-in + darker industrial plastic PBR */
      bottle.traverse(function (node) {
        if (!node.isMesh) return;
        node.castShadow = true;
        node.receiveShadow = true;
        var mats = Array.isArray(node.material) ? node.material : [node.material];
        mats.forEach(function (m) {
          m.transparent = true;
          m.opacity = 0;
          if (m.isMeshStandardMaterial || m.isMeshPhysicalMaterial) {
            /* Darken albedo slightly for richer black plastic */
            if (m.color && m.color.isColor) {
              m.color.multiplyScalar(0.78);
            }
            if (m.emissive && m.emissive.isColor) {
              m.emissive.multiplyScalar(0.35);
            }
            /* Less metal wash, slightly rougher so it stays matte-dark */
            m.metalness = THREE.MathUtils.clamp(
              m.metalness != null ? m.metalness * 0.7 : 0.12,
              0.05,
              0.22
            );
            m.roughness = THREE.MathUtils.clamp(
              m.roughness != null ? Math.max(m.roughness, 0.42) * 1.05 : 0.48,
              0.38,
              0.72
            );
            if (m.envMapIntensity != null) m.envMapIntensity = 0.45;
            m.needsUpdate = true;
          }
        });
      });

      scene.add(bottle);

      setTimeout(function () {
        _hideLoader();
        if (reducedMotion) {
          _quickReveal();
        } else {
          _playEntry();
        }
      }, 400);
    },
    function onProgress() { /* progress UI removed with secondary loader */ },
    function onError(err) {
      clearTimeout(loadTimer);
      console.warn('[FloorX Hero] GLB load error:', err);
      _hideLoader();
      _showHeroFallback();
    }
  );

  /* Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â
     MOUSE INTERACTION
     Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â */
  /* Subtle pointer influence — light moves more than the bottle */
  var MAX_Y = THREE.MathUtils.degToRad(isMobile ? 3 : 5);
  var MAX_X = THREE.MathUtils.degToRad(isMobile ? 2 : 3.5);
  var mNX = 0, mNY = 0;
  var tRotY = 0, tRotX = 0;
  var cRotY = 0, cRotX = 0;

  function onMouseMove(e) {
    mNX =  (e.clientX / window.innerWidth)  * 2 - 1;
    mNY =  (e.clientY / window.innerHeight) * 2 - 1;
    tRotY =  mNX * MAX_Y;
    tRotX = -mNY * MAX_X;
  }
  function onTouchMove(e) {
