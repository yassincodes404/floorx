{%- comment -%}
  FloorX Back-to-top — fixed control, high z-index, works on all pages.
  Shown after a short scroll; sits above page content, below cart drawer.
{%- endcomment -%}

<button
  type="button"
  class="fx-btt"
  id="fx-back-to-top"
  data-fx-back-to-top
  aria-label="Scroll to top"
  hidden
>
  <span class="fx-btt__ring" aria-hidden="true"></span>
  <svg class="fx-btt__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path d="M12 19V5M5 12l7-7 7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
</button>

<style>
  .fx-btt {
    --fx-btt-size: 48px;
    --fx-btt-bottom: max(1.25rem, env(safe-area-inset-bottom, 0px));
    --fx-btt-right: max(1.1rem, env(safe-area-inset-right, 0px));

    position: fixed !important;
    right: var(--fx-btt-right) !important;
    bottom: calc(var(--fx-btt-bottom) + 0.35rem) !important;
    left: auto !important;
    top: auto !important;
    z-index: 9980 !important; /* above page/hero, below header(9999) & cart(10050) */

    width: var(--fx-btt-size) !important;
    height: var(--fx-btt-size) !important;
    min-width: var(--fx-btt-size) !important;
    min-height: var(--fx-btt-size) !important;
    margin: 0 !important;
    padding: 0 !important;

    display: grid !important;
    place-items: center !important;
    border: none !important;
    border-radius: 50% !important;
    cursor: pointer !important;

    color: #0a0a0a !important;
    background: linear-gradient(145deg, #00cfff 0%, #00aaff 100%) !important;
    box-shadow:
      0 0 0 1px rgba(0, 207, 255, 0.25) inset,
      0 8px 24px rgba(0, 170, 255, 0.35),
      0 0 32px rgba(0, 207, 255, 0.2) !important;

    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(10px) scale(0.92);
    transition:
      opacity 0.28s ease,
      visibility 0.28s ease,
      transform 0.28s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.28s ease !important;

    isolation: isolate;
    -webkit-tap-highlight-color: transparent;
  }

  .fx-btt.is-visible {
    opacity: 1 !important;
    visibility: visible !important;
    pointer-events: auto !important;
    transform: translateY(0) scale(1) !important;
  }

  .fx-btt[hidden] {
    display: grid !important; /* keep layout; visibility handled by is-visible */
  }

  .fx-btt__icon {
    width: 20px !important;
    height: 20px !important;
    display: block !important;
    position: relative;
    z-index: 1;
    color: inherit !important;
    pointer-events: none;
  }

  .fx-btt__ring {
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    border: 1.5px solid rgba(0, 207, 255, 0.45);
    opacity: 0.55;
    pointer-events: none;
    animation: fx-btt-pulse 2.4s ease-in-out infinite;
  }

  @keyframes fx-btt-pulse {
    0%, 100% { opacity: 0.35; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(1.06); }
  }

  @media (hover: hover) {
    .fx-btt:hover {
      transform: translateY(-3px) scale(1.05) !important;
      box-shadow:
        0 0 0 1px rgba(0, 207, 255, 0.35) inset,
        0 12px 32px rgba(0, 170, 255, 0.45),
        0 0 40px rgba(0, 207, 255, 0.28) !important;
    }
  }

  .fx-btt:active {
    transform: translateY(0) scale(0.97) !important;
  }

  /* Mobile: clear Instagram FAB (bottom-left) and home indicators */
  @media screen and (max-width: 749px) {
    .fx-btt {
      --fx-btt-size: 46px;
      --fx-btt-bottom: max(1.5rem, env(safe-area-inset-bottom, 0px));
      --fx-btt-right: max(1rem, env(safe-area-inset-right, 0px));
      /* Sit above typical mobile chrome / sticky footers */
      bottom: calc(var(--fx-btt-bottom) + 0.5rem) !important;
    }

    .fx-btt__icon {
      width: 18px !important;
      height: 18px !important;
    }
  }

  /* When cart drawer is open, tuck the control away */
  body.overflow-hidden .fx-btt {
    opacity: 0 !important;
    visibility: hidden !important;
    pointer-events: none !important;
  }

  @media (prefers-reduced-motion: reduce) {
    .fx-btt,
    .fx-btt__ring {
      transition: opacity 0.15s ease !important;
      animation: none !important;
    }
  }
</style>

<script>
  (function () {
    var btn = document.getElementById('fx-back-to-top');
    if (!btn) return;

    /* Escape footer stacking contexts so fixed position is true viewport-fixed */
    if (btn.parentNode !== document.body) {
      document.body.appendChild(btn);
    }

    var SHOW_AFTER = 320;
    var ticking = false;
    var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function scrollY() {
      return window.pageYOffset || document.documentElement.scrollTop || document.body.scrollTop || 0;
    }

    function update() {
      ticking = false;
      var show = scrollY() > SHOW_AFTER;
      btn.classList.toggle('is-visible', show);
      if (show) btn.removeAttribute('hidden');
      else btn.setAttribute('hidden', '');
    }

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }

    btn.addEventListener('click', function (e) {
      e.preventDefault();
      e.stopPropagation();
      try {
        window.scrollTo({ top: 0, left: 0, behavior: reduceMotion ? 'auto' : 'smooth' });
      } catch (err) {
        document.documentElement.scrollTop = 0;
        document.body.scrollTop = 0;
      }
    });

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    document.addEventListener('scroll', onScroll, { passive: true, capture: true });

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', update);
    } else {
      update();
    }
  })();
</script>

{% schema %}
{
  "name": "Scroll to Top Button",
  "disabled_on": {
    "groups": ["header", "custom.popup"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "FloorX back-to-top control. Appears after scrolling ~320px. Works on all pages including the homepage hero."
    }
  ],
  "presets": [
    {
      "name": "Scroll to Top"
    }
  ]
}
{% endschema %}
