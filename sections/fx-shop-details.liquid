{{ 'fx-shop-details.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  FloorX Shop Details — How to Use / Benefits / Description
  Matches Full Shop UI design language + existing fx-shop tokens.
  Sits under the buy panel on the product page.
{%- endcomment -%}

<section
  id="fx-shop-details"
  class="fx-shop-details"
  data-fx-shop-details
  aria-label="{{ 'floorx.shop.product_details' | t }}"
>
  <div class="fx-shop-details__inner">
    <div class="fx-shop-details__shell">
      {%- comment -%} Tab bar — How to Use first {%- endcomment -%}
      <div class="fx-shop-details__tabs" role="tablist" aria-label="{{ 'floorx.shop.product_information' | t }}">
        <button
          type="button"
          class="fx-shop-details__tab is-active"
          role="tab"
          id="fx-sd-tab-howto"
          aria-selected="true"
          aria-controls="fx-sd-panel-howto"
          data-fx-sd-tab="howto"
        >
          <span class="fx-shop-details__tab-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none"><path d="M8 6h11M8 12h11M8 18h11" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><circle cx="5" cy="6" r="1.2" fill="currentColor"/><circle cx="5" cy="12" r="1.2" fill="currentColor"/><circle cx="5" cy="18" r="1.2" fill="currentColor"/></svg>
          </span>
          <span>{{ 'floorx.shop.tab_howto' | t }}</span>
        </button>
        <button
          type="button"
          class="fx-shop-details__tab"
          role="tab"
          id="fx-sd-tab-benefits"
          aria-selected="false"
          aria-controls="fx-sd-panel-benefits"
          data-fx-sd-tab="benefits"
          tabindex="-1"
        >
          <span class="fx-shop-details__tab-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.6"/><path d="M12 8v4l2.5 1.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
          </span>
          <span>{{ 'floorx.shop.tab_benefits' | t }}</span>
        </button>
        <button
          type="button"
          class="fx-shop-details__tab"
          role="tab"
          id="fx-sd-tab-description"
          aria-selected="false"
          aria-controls="fx-sd-panel-description"
          data-fx-sd-tab="description"
          tabindex="-1"
        >
          <span class="fx-shop-details__tab-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none"><rect x="5" y="4" width="14" height="16" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M8 9h8M8 13h6M8 17h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
          </span>
          <span>{{ 'floorx.shop.tab_description' | t }}</span>
        </button>
      </div>

      {%- comment -%} ── HOW TO USE (first / default) ── {%- endcomment -%}
      <div
        class="fx-shop-details__panel is-active"
        role="tabpanel"
        id="fx-sd-panel-howto"
        aria-labelledby="fx-sd-tab-howto"
        data-fx-sd-panel="howto"
      >
        <div class="fx-shop-details__howto">
          {%- assign steps = section.blocks | where: 'type', 'step' -%}
          {%- if steps.size > 0 -%}
            {%- for block in steps -%}
              {%- if forloop.index > 1 -%}
                <span class="fx-shop-details__howto-arrow" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              {%- endif -%}
              <article class="fx-shop-details__scard" {{ block.shopify_attributes }}>
                <span class="fx-shop-details__snum">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 480 | image_tag: loading: 'lazy', class: 'fx-shop-details__simg', widths: '240,360,480', sizes: '160px' }}
                {%- else -%}
                  {%- assign step_asset = 'fx-htu-step-' | append: forloop.index | append: '.jpg' -%}
                  <img class="fx-shop-details__simg" src="{{ step_asset | asset_url }}" alt="" width="240" height="160" loading="lazy">
                {%- endif -%}
                <h3 class="fx-shop-details__stitle">{{ block.settings.title | escape }}</h3>
                <p class="fx-shop-details__stext">{{ block.settings.text | escape }}</p>
              </article>
            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..5) -%}
              {%- assign step_title_key = 'floorx.shop.step' | append: i | append: '_title' -%}
              {%- assign step_text_key = 'floorx.shop.step' | append: i | append: '_text' -%}
              {%- if i > 1 -%}
                <span class="fx-shop-details__howto-arrow" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              {%- endif -%}
              <article class="fx-shop-details__scard">
                <span class="fx-shop-details__snum">0{{ i }}</span>
                <img class="fx-shop-details__simg" src="{{ 'fx-htu-step-' | append: i | append: '.jpg' | asset_url }}" alt="" width="240" height="160" loading="lazy">
                <h3 class="fx-shop-details__stitle">{{ step_title_key | t }}</h3>
                <p class="fx-shop-details__stext">{{ step_text_key | t }}</p>
              </article>
            {%- endfor -%}
          {%- endif -%}

          <div class="fx-shop-details__badge30" aria-label="{{ section.settings.badge_label | default: 'floorx.shop.days_protection' | t | escape }}">
            <strong>30</strong>
            <span>{{ 'floorx.shop.days_protection' | t }}</span>
          </div>
        </div>

        {%- if section.settings.howto_link != blank -%}
          <p class="fx-shop-details__howto-more">
            <a href="{{ section.settings.howto_link }}">{{ 'floorx.shop.full_howto_guide' | t }} →</a>
          </p>
        {%- else -%}
          <p class="fx-shop-details__howto-more">
            <a href="{% if pages['how-to-use'] != blank %}{{ pages['how-to-use'].url }}{% else %}{{ '/pages/how-to-use' | prepend: routes.root_url | replace: '//', '/' }}{% endif %}">{{ 'floorx.shop.full_howto_guide' | t }} →</a>
          </p>
        {%- endif -%}
      </div>

      {%- comment -%} ── BENEFITS ── {%- endcomment -%}
      <div
        class="fx-shop-details__panel"
        role="tabpanel"
        id="fx-sd-panel-benefits"
        aria-labelledby="fx-sd-tab-benefits"
        data-fx-sd-panel="benefits"
        hidden
      >
        <div class="fx-shop-details__benefits">
          {%- liquid
            assign benefits = section.blocks | where: 'type', 'benefit'
          -%}
          {%- if benefits.size > 0 -%}
            {%- for block in benefits -%}
              <article class="fx-shop-details__bcard" {{ block.shopify_attributes }}>
                <span class="fx-shop-details__bicon" aria-hidden="true">
                  {%- case block.settings.icon -%}
                    {%- when 'shield' -%}
                      <svg viewBox="0 0 24 24" fill="none"><path d="M12 3l7 3v6c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z" stroke="currentColor" stroke-width="1.6"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                    {%- when 'fingerprint' -%}
                      <svg viewBox="0 0 24 24" fill="none"><path d="M12 11a3 3 0 00-3 3v3M12 7a7 7 0 017 7v1M5 14v-1a7 7 0 014.5-6.5M12 14v4M9 15.5V17" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                    {%- when 'sparkle' -%}
                      <svg viewBox="0 0 24 24" fill="none"><path d="M12 3l1.2 5.2L18 9l-4.8 1.8L12 16l-1.2-5.2L6 9l4.8-0.8L12 3zM18 15l.6 2.4L21 18l-2.4.6L18 21l-.6-2.4L15 18l2.4-.6L18 15z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>
                    {%- when 'leaf' -%}
                      <svg viewBox="0 0 24 24" fill="none"><path d="M5 19c8 0 12-6 12-14-6 0-12 4-12 12z" stroke="currentColor" stroke-width="1.6"/><path d="M5 19c2-4 6-7 11-8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                    {%- when 'dumbbell' -%}
                      <svg viewBox="0 0 24 24" fill="none"><path d="M6.5 8.5v7M17.5 8.5v7M4 10v4M20 10v4M6.5 12h11" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                    {%- when 'calendar' -%}
                      <svg viewBox="0 0 24 24" fill="none"><rect x="4" y="5" width="16" height="15" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M8 3v4M16 3v4M4 10h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                    {%- else -%}
                      <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.6"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                  {%- endcase -%}
                </span>
                <div class="fx-shop-details__bcopy">
                  <h3 class="fx-shop-details__btitle">{{ block.settings.title | escape }}</h3>
                  <p class="fx-shop-details__btext">{{ block.settings.text | escape }}</p>
                </div>
              </article>
            {%- endfor -%}
          {%- else -%}
            {%- comment -%} Defaults matching design when no blocks {%- endcomment -%}
            <article class="fx-shop-details__bcard">
              <span class="fx-shop-details__bicon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3l7 3v6c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z" stroke="currentColor" stroke-width="1.6"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg></span>
              <div class="fx-shop-details__bcopy"><h3 class="fx-shop-details__btitle">{{ 'floorx.shop.benefit_treadmills_title' | t }}</h3><p class="fx-shop-details__btext">{{ 'floorx.shop.benefit_treadmills_text' | t }}</p></div>
            </article>
            <article class="fx-shop-details__bcard">
              <span class="fx-shop-details__bicon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M12 11a3 3 0 00-3 3v3M12 7a7 7 0 017 7v1M5 14v-1a7 7 0 014.5-6.5M12 14v4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg></span>
              <div class="fx-shop-details__bcopy"><h3 class="fx-shop-details__btitle">{{ 'floorx.shop.benefit_marks_title' | t }}</h3><p class="fx-shop-details__btext">{{ 'floorx.shop.benefit_marks_text' | t }}</p></div>
            </article>
            <article class="fx-shop-details__bcard">
              <span class="fx-shop-details__bicon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3l1.2 5.2L18 9l-4.8 1.8L12 16l-1.2-5.2L6 9l4.8-.8L12 3z" stroke="currentColor" stroke-width="1.4"/></svg></span>
              <div class="fx-shop-details__bcopy"><h3 class="fx-shop-details__btitle">{{ 'floorx.shop.benefit_deep_title' | t }}</h3><p class="fx-shop-details__btext">{{ 'floorx.shop.benefit_deep_text' | t }}</p></div>
            </article>
            <article class="fx-shop-details__bcard">
              <span class="fx-shop-details__bicon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M5 19c8 0 12-6 12-14-6 0-12 4-12 12z" stroke="currentColor" stroke-width="1.6"/><path d="M5 19c2-4 6-7 11-8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg></span>
              <div class="fx-shop-details__bcopy"><h3 class="fx-shop-details__btitle">{{ 'floorx.shop.benefit_gentle_title' | t }}</h3><p class="fx-shop-details__btext">{{ 'floorx.shop.benefit_gentle_text' | t }}</p></div>
            </article>
            <article class="fx-shop-details__bcard">
              <span class="fx-shop-details__bicon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M6.5 8.5v7M17.5 8.5v7M4 10v4M20 10v4M6.5 12h11" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg></span>
              <div class="fx-shop-details__bcopy"><h3 class="fx-shop-details__btitle">{{ 'floorx.shop.benefit_gym_title' | t }}</h3><p class="fx-shop-details__btext">{{ 'floorx.shop.benefit_gym_text' | t }}</p></div>
            </article>
            <article class="fx-shop-details__bcard">
              <span class="fx-shop-details__bicon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><rect x="4" y="5" width="16" height="15" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M8 3v4M16 3v4M4 10h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></span>
              <div class="fx-shop-details__bcopy"><h3 class="fx-shop-details__btitle">{{ 'floorx.shop.benefit_lasting_title' | t }}</h3><p class="fx-shop-details__btext">{{ 'floorx.shop.benefit_lasting_text' | t }}</p></div>
            </article>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} ── DESCRIPTION ── {%- endcomment -%}
      <div
        class="fx-shop-details__panel"
        role="tabpanel"
        id="fx-sd-panel-description"
        aria-labelledby="fx-sd-tab-description"
        data-fx-sd-panel="description"
        hidden
      >
        <div class="fx-shop-details__desc">
          <div class="fx-shop-details__desc-visual">
            {%- if section.settings.desc_image != blank -%}
              {{ section.settings.desc_image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'fx-shop-details__desc-img', widths: '400,600,900', sizes: '(min-width: 990px) 360px, 70vw' }}
            {%- else -%}
              <img
                class="fx-shop-details__desc-img"
                src="{{ 'fx-shop-bottle.jpg' | asset_url }}"
                alt="{{ product.title | escape }}"
                width="600"
                height="720"
                loading="lazy"
              >
            {%- endif -%}
            <div class="fx-shop-details__desc-glow" aria-hidden="true"></div>
          </div>

          <div class="fx-shop-details__desc-body">
            {%- if section.settings.desc_heading != blank -%}
              <h3 class="fx-shop-details__desc-heading">{{ section.settings.desc_heading | escape }}</h3>
            {%- endif -%}
            {%- if section.settings.desc_text != blank -%}
              <div class="fx-shop-details__desc-rte rte">{{ section.settings.desc_text }}</div>
            {%- elsif product.description != blank -%}
              <div class="fx-shop-details__desc-rte rte">{{ product.description }}</div>
            {%- else -%}
              <div class="fx-shop-details__desc-rte rte">
                <p>{{ 'floorx.shop.desc_body' | t }}</p>
              </div>
            {%- endif -%}

            <ul class="fx-shop-details__features">
              {%- assign features = section.blocks | where: 'type', 'feature' -%}
              {%- if features.size > 0 -%}
                {%- for block in features -%}
                  <li class="fx-shop-details__feature" {{ block.shopify_attributes }}>
                    <span class="fx-shop-details__ficon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                    </span>
                    <span>
                      <strong>{{ block.settings.title | escape }}</strong>
                      {%- if block.settings.text != blank -%}
                        <span>{{ block.settings.text | escape }}</span>
                      {%- endif -%}
                    </span>
                  </li>
                {%- endfor -%}
              {%- else -%}
                <li class="fx-shop-details__feature">
                  <span class="fx-shop-details__ficon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M13 3L4 14h7l-1 7 10-12h-7l1-6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg></span>
                  <span><strong>{{ 'floorx.shop.desc_perf_title' | t }}</strong><span>{{ 'floorx.shop.desc_perf_text' | t }}</span></span>
                </li>
                <li class="fx-shop-details__feature">
                  <span class="fx-shop-details__ficon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3l7 3v6c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z" stroke="currentColor" stroke-width="1.5"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></span>
                  <span><strong>{{ 'floorx.shop.desc_pro_title' | t }}</strong><span>{{ 'floorx.shop.desc_pro_text' | t }}</span></span>
                </li>
                <li class="fx-shop-details__feature">
                  <span class="fx-shop-details__ficon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M4 7h16v10H4zM8 7V5h8v2M12 11v2" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg></span>
                  <span><strong>{{ 'floorx.shop.desc_cost_title' | t }}</strong><span>{{ 'floorx.shop.desc_cost_text' | t }}</span></span>
                </li>
                <li class="fx-shop-details__feature">
                  <span class="fx-shop-details__ficon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M7 7h10v10H7zM10 4h4M9 17v3M15 17v3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></span>
                  <span><strong>{{ 'floorx.shop.desc_easy_title' | t }}</strong><span>{{ 'floorx.shop.desc_easy_text' | t }}</span></span>
                </li>
              {%- endif -%}
            </ul>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script src="{{ 'fx-shop-details.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "FX Shop Details",
  "tag": "section",
  "class": "section-fx-shop-details",
  "settings": [
    {
      "type": "text",
      "id": "desc_heading",
      "label": "Description heading",
      "default": "Professional gym floor protection"
    },
    {
      "type": "richtext",
      "id": "desc_text",
      "label": "Description (optional — falls back to product description)"
    },
    {
      "type": "image_picker",
      "id": "desc_image",
      "label": "Description image (optional — uses shop bottle asset)"
    },
    {
      "type": "url",
      "id": "howto_link",
      "label": "Full How to Use page link"
    },
    {
      "type": "text",
      "id": "badge_label",
      "label": "30-day badge label",
      "default": "30 days protection"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit card",
      "limit": 6,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shield", "label": "Shield" },
            { "value": "fingerprint", "label": "Fingerprint" },
            { "value": "sparkle", "label": "Sparkle" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "dumbbell", "label": "Dumbbell" },
            { "value": "calendar", "label": "Calendar" },
            { "value": "check", "label": "Check" }
          ],
          "default": "shield"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Benefit"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Short supporting line."
        }
      ]
    },
    {
      "type": "feature",
      "name": "Description feature",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Short supporting line."
        }
      ]
    },
    {
      "type": "step",
      "name": "How-to step",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Step"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Short step description."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (optional — uses HTU step assets)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FX Shop Details",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "shield", "title": "Safe for treadmills", "text": "Specially designed to be safe for all treadmill belts." } },
        { "type": "benefit", "settings": { "icon": "fingerprint", "title": "Removes marks", "text": "Effectively removes shoe marks, dust and fingerprints." } },
        { "type": "benefit", "settings": { "icon": "sparkle", "title": "Deep cleaning", "text": "Penetrates deep to lift dirt and restore freshness." } },
        { "type": "benefit", "settings": { "icon": "leaf", "title": "Non-abrasive", "text": "Gentle formula that won’t damage rubber surfaces." } },
        { "type": "benefit", "settings": { "icon": "dumbbell", "title": "Gym approved", "text": "Trusted by gyms and fitness centers worldwide." } },
        { "type": "benefit", "settings": { "icon": "calendar", "title": "Long lasting", "text": "Protection and performance that lasts up to 30 days." } },
        { "type": "feature", "settings": { "title": "Better performance", "text": "Improves grip and safety." } },
        { "type": "feature", "settings": { "title": "Professional results", "text": "Delivers a clean, like-new look." } },
        { "type": "feature", "settings": { "title": "Cost effective", "text": "Highly concentrated formula for maximum value." } },
        { "type": "feature", "settings": { "title": "Easy maintenance", "text": "Simple to use, easy to maintain." } },
        { "type": "step", "settings": { "title": "Prep the surface", "text": "Make sure the floor is clean and free from dust." } },
        { "type": "step", "settings": { "title": "Mix the solution", "text": "Add 1.5 KG of FloorX to 12 liters of water and mix well." } },
        { "type": "step", "settings": { "title": "Apply the solution", "text": "Spread the solution evenly using a mop. Do not squeeze the mop." } },
        { "type": "step", "settings": { "title": "Use on treadmills", "text": "Wipe treadmill belts and surfaces with a clean cloth." } },
        { "type": "step", "settings": { "title": "Protected & ready", "text": "Let it dry completely. Your floor is now clean, safe and protected." } }
      ]
    }
  ]
}
{% endschema %}
