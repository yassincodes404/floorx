        "q1": {
          "type": "question",
          "settings": {
            "question": "Is FloorX safe for treadmills?",
            "answer": "Yes. FloorX is safe to use on treadmill belts and gym machines when used as directed."
          }
        },
        "q2": {
          "type": "question",
          "settings": {
            "question": "Can FloorX be used on rubber gym floors?",
            "answer": "Yes. The product is designed to work on rubber gym flooring and help keep it clean and looking better."
          }
        },
        "q3": {
          "type": "question",
          "settings": {
            "question": "How often should FloorX be used?",
            "answer": "In most gyms, using FloorX once every 30 days is enough to maintain a clean appearance."
          }
        },
        "q4": {
          "type": "question",
          "settings": {
            "question": "Does the product damage treadmill belts?",
            "answer": "No. FloorX has been tested on treadmills for more than 2 years to ensure it is safe when used correctly."
          }
        },
        "q5": {
          "type": "question",
          "settings": {
            "question": "Can the product remove shoe marks and fingerprints?",
            "answer": "FloorX helps reduce the appearance of shoe marks and fingerprints that commonly appear on treadmill belts and rubber floors."
          }
        },
        "q6": {
          "type": "question",
          "settings": {
            "question": "Do I need special equipment to use FloorX?",
            "answer": "No special tools are needed. A mop or a clean cloth with the prepared solution is enough."
          }
        },
        "q7": {
          "type": "question",
          "settings": {
            "question": "Where can I use FloorX?",
            "answer": "The product can be used on treadmill belts, rubber gym floors, and some gym machine surfaces."
          }
        }
      },
