{%- liquid
  assign glb_url = 'finalback.glb' | asset_url
  assign h1 = section.settings.heading_line1
  assign h2 = section.settings.heading_line2
  assign h3 = section.settings.heading_line3
  assign sub = section.settings.subheading
  assign btn1_l = section.settings.btn_primary_label
  assign btn1_u = section.settings.btn_primary_url | default: '/products/floorx'
  assign btn2_l = section.settings.btn_secondary_label
  assign btn2_u = section.settings.btn_secondary_url | default: '#'
  assign prob_t = section.settings.problem_title
  assign cta_t = section.settings.cta_title
  assign sid = section.id

  if h1 == blank or h1 == 'REVIVE'
    assign h1 = 'floorx.hero.heading_1' | t
  endif
  if h2 == blank or h2 == 'YOUR'
    assign h2 = 'floorx.hero.heading_2' | t
  endif
  if h3 == blank or h3 == 'GYM.'
    assign h3 = 'floorx.hero.heading_3' | t
  endif
  if sub == blank or sub == 'Professional Floor Restoration for Rubber Floors & Equipment' or sub == 'Professional Rubber Floor Restoration'
    assign sub = 'floorx.hero.subheading' | t
  endif
  if btn1_l == blank or btn1_l == 'Shop Now'
    assign btn1_l = 'floorx.common.shop_now' | t
  endif
  if prob_t == blank or prob_t == 'Why Gym Floors Lose Their Finish' or prob_t == 'Restore worn rubber.\nDeep black finish.' or prob_t == 'Restore worn rubber. Deep black finish.'
    assign prob_t = 'floorx.hero.problem_title_alt' | t
  endif
  if cta_t == blank or cta_t == 'Ready To Transform Your Gym?' or cta_t == 'Ready to Transform Your Gym?'
    assign cta_t = 'floorx.hero.cta_title' | t
  endif

  if btn1_u == '/products/floorx' or btn1_u == blank
    assign btn1_u = '/products/floorx' | prepend: routes.root_url | replace: '//', '/'
  endif
-%}

