<!-- â• â• â• â• â• â• â• â• â• â• â• â• â• â•  CDN DEPENDENCIES (UMD globals, Shopify-CSP safe) â• â• â• â• â• â• â• â• â• â• â• â• â• â•  -->
<!-- Three.js r148 — local assets -->
<script src="{{ 'three.min.js' | asset_url }}"></script>
<script src="{{ 'fx-gltf-loader.js' | asset_url }}"></script>
<!-- GSAP + ScrollTrigger (cdnjs â€” already whitelisted in Shopify) -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

<!-- â• â• â• â• â• â• â• â• â• â• â• â• â• â•  MAIN SCRIPT â• â• â• â• â• â• â• â• â• â• â• â• â• â•  -->
<script>
(function FXCinematicHero() {
  'use strict';

  const SID     = '{{ sid }}';
  const GLB_URL = '{{ glb_url }}';

  /* â”€â”€ Safety: dismiss loader after 20s regardless â”€â”€â”€â”€â”€â”€â”€ */
  var _safetyTimer = setTimeout(function () {
    _hideLoader();
    _showHeroFallback();
  }, 20000);

  function _hideLoader() {
    var el = document.getElementById('fxch-load-' + SID);
    if (el) el.classList.add('is-hidden');
    clearTimeout(_safetyTimer);
  }
  function _showHeroFallback() {
    var hp = document.getElementById('fxch-hero-' + SID);
    if (hp) { hp.style.opacity = '1'; hp.style.pointerEvents = 'auto'; }
    var ind = document.getElementById('fxch-ind-' + SID);
    if (ind) ind.style.opacity = '1';
  }

  /* â”€â”€ Guard: Three.js must be loaded â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
  if (typeof THREE === 'undefined' || typeof THREE.GLTFLoader === 'undefined') {
    console.warn('[FloorX Hero] Three.js / GLTFLoader not available â€” showing fallback');
    setTimeout(function () { _hideLoader(); _showHeroFallback(); }, 800);
    return;
  }

  /* â”€â”€ Guard: GSAP must be loaded â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
  if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
    console.warn('[FloorX Hero] GSAP not available â€” showing fallback');
    setTimeout(function () { _hideLoader(); _showHeroFallback(); }, 800);
    return;
  }
  gsap.registerPlugin(ScrollTrigger);

  /* ── Header glass-on-scroll ───────────────────────────── */
  var _headerWrapper = document.querySelector('.header-wrapper');
  function _updateHeader() {
    if (!_headerWrapper) return;
    var heroEnd = window.innerHeight * 2.4; /* 80% of 300vh */
    if (window.scrollY > heroEnd) {
      _headerWrapper.classList.add('scrolled');
    } else {
      _headerWrapper.classList.remove('scrolled');
    }
  }
  window.addEventListener('scroll', _updateHeader, { passive: true });
  _updateHeader();

  var isMobile      = window.innerWidth < 768;
  var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* â”€â”€ DOM refs â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
  var barEl     = document.getElementById('fxch-bar-'    + SID);
  var lblEl     = document.getElementById('fxch-lbl-'    + SID);
  var canvasEl  = document.getElementById('fxch-canvas-' + SID);
  var ptsCanvas = document.getElementById('fxch-pts-'    + SID);
  var glowEl    = document.getElementById('fxch-glow-'   + SID);
  var reflectEl = document.getElementById('fxch-ref-'    + SID);
  var scrollInd = document.getElementById('fxch-ind-'    + SID);
  var pHero     = document.getElementById('fxch-hero-'   + SID);
  var pProb     = document.getElementById('fxch-prob-'   + SID);
  var pFeat     = document.getElementById('fxch-feat-'   + SID);
  var pStats    = document.getElementById('fxch-stats-'  + SID);
  var pCta      = document.getElementById('fxch-cta-'    + SID);

  /* â”€â”€ Animated state (GSAP animates this plain object) â”€â”€â”€ */
  var S = {
    sceneOpacity:    0,
    glowOpacity:     0,
    reflectStrength: 0,
    camZ:  5.5, camX: 0.0, camY: 0.0,
    btlX:  0.70, btlY: -0.5, btlOpacity: 0,
    rimInt: 0, keyInt: 0, ambInt: 0,
    opHero: 0, opProb: 0, opFeat: 0, opStats: 0, opCta: 0, opInd: 0,
  };

  /* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
     THREE.JS SCENE SETUP
     â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
  var renderer, scene, camera;
  var ambLight, keyLight, fillLight, rimLight, hemiLight;
  var bottle = null;
  var webglOK = false;

  try {
    renderer = new THREE.WebGLRenderer({
      canvas: canvasEl,
      antialias: !isMobile,
      alpha: false,
      powerPreference: 'high-performance',
    });
    var initW = window.innerWidth;
    var initH = window.innerHeight;

    renderer.setPixelRatio(Math.min(window.devicePixelRatio, isMobile ? 1.5 : 2));
    renderer.setSize(initW, initH);
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.25;
    renderer.outputEncoding = THREE.sRGBEncoding; /* Required for GLTF */
    renderer.shadowMap.enabled = !isMobile;
    renderer.shadowMap.type = THREE.PCFSoftShadowMap;

    scene = new THREE.Scene();
    scene.background = new THREE.Color(0x05060A);
    scene.fog = new THREE.FogExp2(0x060810, 0.1);

    camera = new THREE.PerspectiveCamera(33, initW / initH, 0.05, 80);
    camera.position.set(0, 0, 5.5);

    ambLight = new THREE.AmbientLight(0xffffff, 0); /* Changed to white */
    scene.add(ambLight);

    hemiLight = new THREE.HemisphereLight(0x7DF9FF, 0x05060A, 0); /* Ambient reflection */
    scene.add(hemiLight);

    keyLight = new THREE.DirectionalLight(0xF0F8FF, 0);
    keyLight.position.set(3, 5, 4);
    keyLight.castShadow = !isMobile;
    if (!isMobile) {
      keyLight.shadow.mapSize.set(1024, 1024);
      keyLight.shadow.bias = -0.001;
    }
    scene.add(keyLight);

    fillLight = new THREE.PointLight(0x7DF9FF, 0, 12);
    fillLight.position.set(-3, 0.5, 2);
    scene.add(fillLight);

    rimLight = new THREE.PointLight(0x7DF9FF, 0, 18);
    rimLight.position.set(-1, 1.5, -2);
    scene.add(rimLight);

    /* Large background sphere */
    scene.add(new THREE.Mesh(
      new THREE.SphereGeometry(22, 6, 6),
      new THREE.MeshBasicMaterial({ color: 0x060810, side: THREE.BackSide })
    ));

    /* Floor plane */
    var floorMat = new THREE.MeshStandardMaterial({
      color: 0x060810, metalness: 0.9, roughness: 0.3,
      transparent: true, opacity: 0,
    });
    var floor = new THREE.Mesh(new THREE.PlaneGeometry(12, 12), floorMat);
    floor.rotation.x = -Math.PI / 2;
    floor.position.y = -1.8;
    floor.receiveShadow = true;
    scene.add(floor);

    webglOK = true;
  } catch (e) {
    console.warn('[FloorX Hero] WebGL init failed:', e);
    _hideLoader();
    _showHeroFallback();
    return;
  }

  /* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
     LOAD GLB MODEL
     â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
  if (lblEl) lblEl.textContent = 'Loading Model';

  var gltfLoader = new THREE.GLTFLoader();


  /* Timeout on model load: 25 seconds */
  var loadTimer = setTimeout(function () {
    console.warn('[FloorX Hero] GLB load timeout â€” showing fallback');
    _hideLoader();
    _showHeroFallback();
  }, 25000);

  gltfLoader.load(
    GLB_URL,
    function onGLBLoaded(gltf) {
      clearTimeout(loadTimer);

      bottle = gltf.scene;

      /* Auto-scale */
      var bbox = new THREE.Box3().setFromObject(bottle);
      var bSize = bbox.getSize(new THREE.Vector3());
      var maxDim = Math.max(bSize.x, bSize.y, bSize.z);
      var targetSize = isMobile ? 1.4 : 1.75;
      var scl = targetSize / maxDim;
      bottle.scale.setScalar(scl);

      /* Centre on bounding-box centroid */
      var bCentre = bbox.getCenter(new THREE.Vector3());
      bottle.position.sub(bCentre.multiplyScalar(scl));

      /* Enable shadows + transparent for fade-in + tweak PBR */
      bottle.traverse(function (node) {
        if (!node.isMesh) return;
        node.castShadow = true;
        node.receiveShadow = true;
        var mats = Array.isArray(node.material) ? node.material : [node.material];
        mats.forEach(function (m) {
          m.transparent = true;
          m.opacity = 0;
          if (m.isMeshStandardMaterial || m.isMeshPhysicalMaterial) {
            /* Drop metalness so diffuse maps are visible without envMap */
            m.metalness = Math.min(m.metalness, 0.4);
            m.roughness = Math.max(m.roughness, 0.3);
          }
        });
      });

      scene.add(bottle);

      if (barEl) barEl.style.width = '100%';
      if (lblEl) lblEl.textContent = 'Ready';

      setTimeout(function () {
        _hideLoader();
        if (reducedMotion) {
          _quickReveal();
        } else {
          _playEntry();
        }
      }, 400);
    },
    function onProgress(prog) {
      if (prog.lengthComputable && barEl) {
        var pct = Math.round((prog.loaded / prog.total) * 100);
        barEl.style.width = pct + '%';
        if (lblEl) lblEl.textContent = 'Loading ' + pct + '%';
      }
    },
    function onError(err) {
      clearTimeout(loadTimer);
      console.warn('[FloorX Hero] GLB load error:', err);
      _hideLoader();
      _showHeroFallback();
    }
  );

  /* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
     MOUSE INTERACTION
     â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
  var MAX_Y = THREE.MathUtils.degToRad(18);
  var MAX_X = THREE.MathUtils.degToRad(8);
  var mNX = 0, mNY = 0;
  var tRotY = 0, tRotX = 0;
  var cRotY = 0, cRotX = 0;

  function onMouseMove(e) {
    mNX =  (e.clientX / window.innerWidth)  * 2 - 1;
    mNY =  (e.clientY / window.innerHeight) * 2 - 1;
    tRotY =  mNX * MAX_Y;
    tRotX = -mNY * MAX_X;
  }
  function onTouchMove(e) {
    if (!e.touches[0]) return;
    mNX =  (e.touches[0].clientX / window.innerWidth)  * 2 - 1;
    mNY =  (e.touches[0].clientY / window.innerHeight) * 2 - 1;
    tRotY =  mNX * MAX_Y * 0.5;
    tRotX = -mNY * MAX_X * 0.5;
  }
  window.addEventListener('mousemove', onMouseMove, { passive: true });
  window.addEventListener('touchmove', onTouchMove, { passive: true });

  /* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
     PARTICLE SYSTEM
     â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
  var pCtx = ptsCanvas ? ptsCanvas.getContext('2d') : null;
  var PART_COUNT = isMobile ? 0 : 55;
  var parts = [];

  function _makePart() {
    return {
      x: Math.random() * window.innerWidth,
      y: Math.random() * window.innerHeight,
      r: 1 + Math.random() * 2.2,
      spd: 0.14 + Math.random() * 0.32,
      op: 0.18 + Math.random() * 0.48,
      drift: (Math.random() - 0.5) * 0.28,
      ph: Math.random() * Math.PI * 2,
    };
  }
  function _resizeParts() {
    if (!ptsCanvas) return;
    ptsCanvas.width  = window.innerWidth;
    ptsCanvas.height = window.innerHeight;
  }
  if (pCtx && !reducedMotion) {
    _resizeParts();
    for (var _i = 0; _i < PART_COUNT; _i++) parts.push(_makePart());
  }

  function _tickParticles(t) {
    if (!pCtx || !parts.length) return;
    pCtx.clearRect(0, 0, ptsCanvas.width, ptsCanvas.height);
    for (var _j = 0; _j < parts.length; _j++) {
      var p = parts[_j];
      p.y -= p.spd;
      p.x += p.drift * Math.sin(t * 0.0008 + p.ph);
      if (p.y < -8) { p.y = ptsCanvas.height + 8; p.x = Math.random() * ptsCanvas.width; }
      pCtx.beginPath();
      pCtx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      pCtx.fillStyle = 'rgba(125,249,255,' + (p.op * S.sceneOpacity) + ')';
      pCtx.fill();
    }
  }

  /* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
     RENDER LOOP
     â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
  var idleT = 0, lastT = 0, rafId;

  function _applyScene() {
    if (!webglOK || !bottle) return;

    var idleY  = Math.sin(idleT * 0.54) * 0.075;
    var idleRY = Math.sin(idleT * 0.27) * 0.011;
    var idleRZ = Math.sin(idleT * 0.17) * 0.006;
    var breath = 1 + Math.sin(idleT * 0.38) * 0.048;

    bottle.position.x = S.btlX;
    bottle.position.y = S.btlY + (reducedMotion ? 0 : idleY);

    cRotY += (tRotY - cRotY) * 0.038;
    cRotX += (tRotX - cRotX) * 0.038;
    bottle.rotation.x = cRotX;
    bottle.rotation.y = cRotY + (reducedMotion ? 0 : idleRY);
    bottle.rotation.z = cRotX * 0.28 + (reducedMotion ? 0 : idleRZ);

    bottle.traverse(function (node) {
      if (!node.isMesh) return;
      var mats = Array.isArray(node.material) ? node.material : [node.material];
      mats.forEach(function (m) { m.opacity = S.btlOpacity; });
    });

    camera.position.set(S.camX, S.camY, S.camZ);
    camera.lookAt(S.btlX * 0.45, S.btlY * 0.45 + 0.3, 0);

    rimLight.intensity  = S.rimInt * breath;
    keyLight.intensity  = S.keyInt * 2.5; /* Boosted 2.5x */
    ambLight.intensity  = S.ambInt * breath * 4.0; /* Boosted 4x */
    hemiLight.intensity = S.ambInt * 5.0; /* Boosted ambient reflection */
    fillLight.intensity = S.rimInt * 0.8;
    rimLight.position.set(
      S.btlX - 1.3 + mNX * 1.6,
      S.btlY + 1.6 + mNY * 0.55,
      -1.8
    );

    canvasEl.style.opacity = S.sceneOpacity;
  }

  function _setOp(el, val, pe, ariaHide) {
    if (!el) return;
    el.style.opacity = val;
    el.style.pointerEvents = val > 0.01 ? pe : 'none';
    if (ariaHide) el.setAttribute('aria-hidden', val < 0.1 ? 'true' : 'false');
  }

  function _applyPanels() {
    _setOp(pHero,  S.opHero,  'auto', false);
    _setOp(pProb,  S.opProb,  'none', true);
    _setOp(pFeat,  S.opFeat,  'none', true);
    _setOp(pStats, S.opStats, 'none', true);
    _setOp(pCta,   S.opCta,   'auto', true);
    if (scrollInd) scrollInd.style.opacity = S.opInd;
  }

  function _applyAtmo() {
    if (glowEl) {
      glowEl.style.left    = (50 + mNX * 7) + '%';
      glowEl.style.top     = (50 - mNY * 4.5) + '%';
      glowEl.style.opacity = S.glowOpacity;
    }
    if (reflectEl) reflectEl.style.opacity = S.reflectStrength;
  }

  function _frame(ts) {
    rafId = requestAnimationFrame(_frame);
    var dt = Math.min((ts - lastT) / 1000, 0.05);
    lastT = ts;
    idleT += dt;
    _applyScene();
    _applyPanels();
    _applyAtmo();
    _tickParticles(ts);
    if (webglOK) renderer.render(scene, camera);
  }
  requestAnimationFrame(_frame);

  /* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
     ENTRY ANIMATION
     â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
  function _playEntry() {
    gsap.timeline({ onComplete: _buildScrollTimeline })
      .to(S, { sceneOpacity: 1, duration: 1.4, ease: 'power2.inOut' },       0)
      .to(S, { glowOpacity:  0.38, duration: 2.0, ease: 'power1.inOut' },    0.4)
      .to(S, { btlOpacity:   1,   duration: 2.2, ease: 'power3.out' },       0.7)
      .to(S, { ambInt: 0.28,      duration: 1.8, ease: 'power1.inOut' },     0.9)
      .to(S, { rimInt: 2.0,       duration: 1.8, ease: 'power2.out' },       1.1)
      .to(S, { keyInt: 1.8,       duration: 1.5, ease: 'power1.out' },       1.3)
      .to(S, { opHero: 1,         duration: 1.1, ease: 'power2.out' },       1.9)
      .to(S, { opInd:  1,         duration: 0.8, ease: 'none' },             2.9);
  }

  function _quickReveal() {
    S.sceneOpacity = 1; S.glowOpacity = 0.38; S.btlOpacity = 1;
    S.ambInt = 0.28; S.rimInt = 2; S.keyInt = 1.8;
    S.opHero = 1; S.opInd = 1;
    _buildScrollTimeline();
  }

  /* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
     SCROLL TIMELINE â€” 300vh cinematic camera shot
     â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
  function _buildScrollTimeline() {
    var tl = gsap.timeline({
      scrollTrigger: {
        trigger: '#fx-ch-' + SID,
        start: 'top top',
        end:   'bottom bottom',
        scrub: 2.0,
      }
    });

    /* 0 → 0.18: Camera slowly drifts toward bottle */
    tl.to(S, { camZ: 5.0, camX:  0.12, duration: 0.18, ease: 'power1.inOut' }, 0)
    /* 0.15: Hero + scroll ind fade */
      .to(S, { opHero: 0,  duration: 0.10, ease: 'power2.in' }, 0.15)
      .to(S, { opInd:  0,  duration: 0.07, ease: 'none' },      0.13)
    /* 0.22 → 0.44: Bottle floats LEFT — Problem appears right */
      .to(S, { btlX: -0.75, camX: 0.38, camZ: 4.8, duration: 0.22, ease: 'power2.inOut' }, 0.22)
      .to(S, { glowOpacity: 0.52, duration: 0.14, ease: 'none' }, 0.26)
      .to(S, { opProb: 1, duration: 0.11, ease: 'power2.out' }, 0.30)
    /* 0.44: Problem fades */
      .to(S, { opProb: 0, duration: 0.08, ease: 'power1.in' }, 0.44)
    /* 0.50 → 0.66: Bottle rises slightly, camera tilts — Features appear left */
      .to(S, { btlY: -0.2, btlX: -0.52, camY: -0.15, rimInt: 3.2, duration: 0.18, ease: 'power2.inOut' }, 0.50)
      .to(S, { opFeat: 1, reflectStrength: 0.45, duration: 0.12, ease: 'power2.out' }, 0.54)
    /* 0.65: Features fade */
      .to(S, { opFeat: 0, duration: 0.07, ease: 'power1.in' }, 0.65)
    /* 0.68 → 0.82: Bottle crosses RIGHT — Stats appear */
      .to(S, { btlX: 0.65, btlY: -0.08, camX: -0.22, camY: 0, duration: 0.20, ease: 'power2.inOut' }, 0.68)
      .to(S, { reflectStrength: 0.82, glowOpacity: 0.70, duration: 0.14, ease: 'none' }, 0.70)
      .to(S, { opStats: 1, duration: 0.11, ease: 'power2.out' }, 0.72)
    /* 0.82: Stats fade */
      .to(S, { opStats: 0, duration: 0.07, ease: 'power1.in' }, 0.82)
    /* 0.84 → 0.96: FINAL HERO SHOT — bottle centres, camera closest */
      .to(S, { btlX: 0, btlY: -0.1, camX: 0, camY: 0, camZ: 4.0, duration: 0.14, ease: 'power3.out' }, 0.84)
      .to(S, { rimInt: 5.5, keyInt: 2.8, glowOpacity: 0.90, duration: 0.12, ease: 'none' }, 0.86)
      .to(S, { opCta: 1, duration: 0.10, ease: 'power2.out' }, 0.88)
    /* 0.96 â†’ 1.0: Fade to black, Shopify page begins */
      .to(S, { opCta: 0, sceneOpacity: 0, glowOpacity: 0, rimInt: 0, reflectStrength: 0, duration: 0.05, ease: 'power2.in' }, 0.96);
  }

  /* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
     RESIZE
     â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
  function onResize() {
    if (!webglOK) return;
    var w = window.innerWidth;
    var h = window.innerHeight;
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
    renderer.setSize(w, h);
    _resizeParts();
    if (typeof ScrollTrigger !== 'undefined') ScrollTrigger.refresh();
  }
  window.addEventListener('resize', onResize, { passive: true });

  /* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
     SHOPIFY SECTION TEARDOWN
     â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
  document.addEventListener('shopify:section:unload', function (e) {
    if (e.detail.sectionId !== SID) return;
    cancelAnimationFrame(rafId);
    window.removeEventListener('mousemove', onMouseMove);
    window.removeEventListener('touchmove', onTouchMove);
    window.removeEventListener('resize', onResize);
    if (typeof ScrollTrigger !== 'undefined') ScrollTrigger.getAll().forEach(function (t) { t.kill(); });
    if (renderer) renderer.dispose();
  });

})();
</script>

