/* â”€â”€â”€ BUTTONS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.fxch-cta-row {
  display: flex;
  gap: 14px;
  align-items: center;
  flex-wrap: wrap;
}

.fxch-panel--cta .fxch-cta-row {
  justify-content: center;
  margin-bottom: 22px;
}

.fxch-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 0 2rem;
  min-height: 54px;
  border-radius: 8px;
  font-family: var(--fxch-body);
  font-size: 0.9375rem;
  font-weight: 600;
  letter-spacing: .12em;
  text-transform: uppercase;
  text-decoration: none;
  cursor: pointer;
  transition: transform .3s cubic-bezier(0.22,1,0.36,1),
              box-shadow .3s cubic-bezier(0.22,1,0.36,1),
              background .25s ease,
              border-color .25s ease,
              color .25s ease;
  white-space: nowrap;
}

.fxch-btn--primary {
  background: var(--fxch-accent);
  color: var(--fx-bg-0, #04060A);
  border: 1px solid var(--fxch-accent);
  box-shadow:
    0 0 36px rgba(125,249,255,.4),
    0 8px 24px rgba(0,0,0,.3);
  position: relative;
}
.fxch-btn--primary::after {
  content: '';
  position: absolute;
  inset: -6px;
  border-radius: 12px;
  background: radial-gradient(ellipse at 50% 100%,
    rgba(125,249,255,.35) 0%,
    transparent 70%);
  opacity: 0;
  z-index: -1;
  transition: opacity .35s ease, transform .35s ease;
  pointer-events: none;
}
.fxch-btn--primary:hover {
  background: #c8fffe;
  box-shadow:
    0 0 56px rgba(125,249,255,.7),
    0 0 90px rgba(29,106,255,.25),
    0 10px 28px rgba(0,0,0,.35);
  transform: translateY(-2px);
}
.fxch-btn--primary:hover::after {
  opacity: 1;
  transform: translateY(4px) scale(1.05);
}
.fxch-btn--primary:active { transform: translateY(-1px) scale(0.985); }
.fxch-btn--primary svg { transition: transform .3s cubic-bezier(0.22,1,0.36,1); }
.fxch-btn--primary:hover svg { transform: translateX(6px); }

.fxch-btn--ghost {
  background: rgba(255,255,255,0.03);
  color: var(--fxch-text);
  border: 1px solid rgba(125,249,255,.25);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}
.fxch-btn--ghost:hover {
  border-color: var(--fxch-accent);
  color: var(--fxch-accent);
  transform: translateY(-2px);
  box-shadow: 0 0 24px rgba(125,249,255,.15);
}

.fxch-btn--lg {
  min-height: 58px;
  padding: 0 2.5rem;
  font-size: 1rem;
}

@media screen and (max-width: 749px) {
  .fxch-btn {
    padding: 10px 20px;
    font-size: 12px;
  }
  .fxch-btn--lg {
    padding: 13px 26px;
    font-size: 13px;
  }
  .fxch-cta-row {
    gap: 10px;
  }
}

/* Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ PROBLEM LIST Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ */
.fxch-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.fxch-list li {
